<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Report Types -->
  <record id="report_type_daily"    model="waqf.report.type"><field name="name">تقرير الموقع اليومي</field><field name="code">daily</field></record>
  <record id="report_type_weekly"   model="waqf.report.type"><field name="name">تقرير الجودة الأسبوعي</field><field name="code">weekly</field></record>
  <record id="report_type_monthly"  model="waqf.report.type"><field name="name">تقرير التقدم الشهري</field><field name="code">monthly</field></record>
  <record id="report_type_itp"      model="waqf.report.type"><field name="name">فحص ITP</field><field name="code">itp</field></record>
  <record id="report_type_hse"      model="waqf.report.type"><field name="name">تقرير السلامة والصحة والبيئة</field><field name="code">hse</field></record>
  <record id="report_type_handover" model="waqf.report.type"><field name="name">فحص الاستلام</field><field name="code">handover</field></record>

  <!-- Invite Email Template -->
  <record id="mail_template_portal_invite" model="mail.template">
    <field name="name">دعوة مستخدم بوابة ماذن</field>
    <field name="model_id" ref="waqf_portal_access.model_waqf_portal_user"/>
    <field name="subject">دعوة للوصول إلى  لمنصة ماذن</field>
    <field name="email_to">{{ object.email }}</field>
    <field name="email_from">{{ (user.email_formatted or user.company_id.email) }}</field>
    <field name="body_html"><![CDATA[
<div style="font-family:'IBM Plex Sans Arabic',Arial,sans-serif;direction:rtl;
            max-width:600px;margin:0 auto;background:#fff;border-radius:12px;
            overflow:hidden;border:1px solid #E0E6ED">

  <!-- Header -->
  <div style="background:linear-gradient(135deg,#0F2234,#1B3A52);
              padding:32px 40px;text-align:center">
    <div style="width:56px;height:56px;background:#C8A454;border-radius:14px;
                display:inline-flex;align-items:center;justify-content:center;
                font-size:24px;font-weight:800;color:#0F2234;margin-bottom:16px">و</div>
    <h1 style="color:#fff;font-size:20px;margin:0;font-weight:700">
      وقف الملك عبدالله بن عبدالعزيز
    </h1>
    <p style="color:#E2C07A;font-size:13px;margin:6px 0 0">
      بوابة إدارة مشاريع تأهيل المساجد
    </p>
  </div>

  <!-- Body -->
  <div style="padding:32px 40px">
    <p style="font-size:15px;color:#1B3A52;margin:0 0 8px">
      السلام عليكم ورحمة الله، <strong t-out="object.name">الاسم</strong>
    </p>
    <p style="font-size:13px;color:#4A6070;line-height:1.8">
      تم إضافتك في منظومة إدارة مشاريع تأهيل المساجد.
      يمكنك الآن الدخول إلى البوابة الإلكترونية باستخدام بياناتك أدناه.
    </p>

    <!-- Credentials Box -->
    <div style="background:#F7F9FC;border:1px solid #E0E6ED;border-radius:10px;
                padding:20px 24px;margin:24px 0">
      <p style="font-size:12px;font-weight:700;color:#8FA3B3;margin:0 0 12px">
        بيانات الدخول
      </p>
      <table style="width:100%;border-collapse:collapse">
        <tr>
          <td style="padding:8px 0;font-size:13px;color:#4A6070;width:40%">
            البريد الإلكتروني:
          </td>
          <td style="padding:8px 0;font-size:13px;font-weight:600;
                     color:#1B3A52;font-family:monospace"
              t-out="object.email">email</td>
        </tr>
        <tr>
          <td style="padding:8px 0;font-size:13px;color:#4A6070">
            رابط البوابة:
          </td>
          <td style="padding:8px 0">
            <a t-att-href="object.portal_url"
               style="color:#237292;font-size:13px;font-weight:600"
               t-out="object.portal_url">portal_url</a>
          </td>
        </tr>
      </table>
    </div>

    <!-- CTA Button -->
    <div style="text-align:center;margin:28px 0">
      <a t-att-href="object.portal_url"
         style="background:#237292;color:#fff;padding:14px 36px;
                border-radius:10px;font-size:14px;font-weight:700;
                text-decoration:none;display:inline-block">
        دخول البوابة
      </a>
    </div>

    <p style="font-size:11px;color:#8FA3B3;line-height:1.7;text-align:center">
      إذا واجهتك أي مشكلة في الدخول، تواصل مع فريق تقنية المعلومات<br/>
      <a href="mailto:it@kawaqf.org" style="color:#237292">it@kawaqf.org</a>
    </p>
  </div>

  <!-- Footer -->
  <div style="background:#F7F9FC;padding:16px 40px;text-align:center;
              border-top:1px solid #E0E6ED">
    <p style="font-size:11px;color:#8FA3B3;margin:0">
      © 2026 وقف الملك عبدالله بن عبدالعزيز لوالديه — جميع الحقوق محفوظة
    </p>
  </div>
</div>
]]></field>
  </record>
</odoo>
