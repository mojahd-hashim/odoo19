<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_boq_import_wizard" model="ir.ui.view">
        <field name="name">mosque.boq.import.wizard.form</field>
        <field name="model">mosque.boq.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import BOQ Data">
                <sheet>
                    <group string="Import Settings" invisible="state == 'done'">
                        <field name="import_mode" widget="radio"/>
                        <field name="file_data"
                               filename="file_name"
                               widget="binary"
                               invisible="import_mode == 'all'"
                               string="Upload File"/>
                        <field name="file_name" invisible="1"/>
                        <field name="overwrite"/>
                        <field name="mosque_ids" widget="many2many_tags"
                               placeholder="Leave empty = import all mosques"/>
                    </group>

                    <group string="Result" invisible="state != 'done'">
                        <field name="result_summary" nolabel="1"
                               style="white-space:pre; font-family:monospace;
                                      font-size:13px; padding:12px;
                                      background:var(--color-background-secondary);
                                      border-radius:6px; line-height:1.8"/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_import" string="Import BOQ"
                            type="object" class="btn-primary"
                            invisible="state == 'done'"/>
                    <button name="action_close" string="Close"
                            type="object" class="btn-secondary"
                            invisible="state != 'done'"/>
                    <button special="cancel" string="Cancel"
                            invisible="state == 'done'"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_boq_import_wizard" model="ir.actions.act_window">
        <field name="name">Import BOQ from Excel</field>
        <field name="res_model">mosque.boq.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_import_mode': 'all'}</field>
    </record>
</odoo>
