<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Groups ─────────────────────────────────────────────── -->
    <record id="group_mosque_contractor" model="res.groups">
        <field name="name">Mosque / Contractor</field>
        <field name="category_ids" ref="base.module_category_project"/>
        <field name="comment">Contractors can add BOQ progress and upload evidence photos.</field>
    </record>

    <record id="group_mosque_consultant" model="res.groups">
        <field name="name">Mosque / Consultant (Supervisor)</field>
        <field name="category_ids" ref="base.module_category_project"/>
        <field name="implied_ids" eval="[(4, ref('group_mosque_contractor'))]"/>
        <field name="comment">Consultants can approve supervision reports and certificates at stage 1.</field>
    </record>

    <record id="group_mosque_waqf_manager" model="res.groups">
        <field name="name">Mosque / Waqf Project Manager</field>
        <field name="category_ids" ref="base.module_category_project"/>
        <field name="implied_ids" eval="[(4, ref('group_mosque_consultant'))]"/>
        <field name="comment">Waqf managers have full read access and approve certificates at stage 2.</field>
    </record>

    <record id="group_mosque_admin" model="res.groups">
        <field name="name">Mosque / Administrator</field>
        <field name="category_ids" ref="base.module_category_project"/>
        <field name="implied_ids" eval="[(4, ref('group_mosque_waqf_manager'))]"/>
        <field name="comment">Full configuration and deletion access.</field>
    </record>

    <!-- ── Record Rules ───────────────────────────────────────── -->
    <!-- Contractor sees only mosques assigned to their project -->
    <record id="rule_mosque_contractor" model="ir.rule">
        <field name="name">Mosque: Contractor sees assigned mosques only</field>
        <field name="model_id" ref="model_mosque_mosque"/>
        <field name="domain_force">[('resident_engineer_id.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_mosque_contractor'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Waqf manager sees all -->
    <record id="rule_mosque_waqf_all" model="ir.rule">
        <field name="name">Mosque: Waqf manager sees all mosques</field>
        <field name="model_id" ref="model_mosque_mosque"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_mosque_waqf_manager'))]"/>
    </record>
</odoo>
