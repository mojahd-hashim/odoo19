    <!-- Empty views for remaining models -->
    <record id="view_certificate_form2" model="ir.ui.view">
        <field name="name">mosque.certificate.form2</field>
        <field name="model">mosque.certificate</field>
        <field name="inherit_id" ref="waqf_mosque_rehab.view_certificate_form"/>
        <field name="arch" type="xml"><data/></field>
    </record>

    <record id="view_change_order_form" model="ir.ui.view">
        <field name="name">mosque.change.order.form</field>
        <field name="model">mosque.change.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit for Review"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-success"
                            invisible="state != 'review'"
                            groups="waqf_mosque_rehab.group_mosque_waqf_manager"/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="state != 'review'"
                            groups="waqf_mosque_rehab.group_mosque_waqf_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,review,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="mosque_id"/>
                            <field name="type"/>
                            <field name="amount"/>
                            <field name="days_extension"/>
                        </group>
                        <group>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                    </group>
                    <field name="reason" placeholder="Detailed justification for the change order..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_attendance_form" model="ir.ui.view">
        <field name="name">mosque.attendance.form</field>
        <field name="model">mosque.attendance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="mosque_id" readonly="1"/>
                            <field name="engineer_id" readonly="1"/>
                            <field name="visit_type" readonly="1"/>
                            <field name="check_in" readonly="1"/>
                            <field name="check_out" readonly="1"/>
                            <field name="duration" readonly="1"/>
                        </group>
                        <group string="GPS Validation">
                            <field name="gps_latitude" readonly="1"/>
                            <field name="gps_longitude" readonly="1"/>
                            <field name="distance_m" readonly="1"/>
                            <field name="gps_validated" widget="boolean_toggle" readonly="1"/>
                            <field name="qr_validated"  widget="boolean_toggle" readonly="1"/>
                            <field name="is_validated"  widget="boolean_toggle" readonly="1"/>
                        </group>
                    </group>
                    <field name="live_stream_url" widget="url"
                           placeholder="Live stream URL during visit..."/>
                    <field name="notes" placeholder="Visit notes..."/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
