<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══ SUPERVISION ════════════════════════════════════════ -->
    <record id="view_supervision_form" model="ir.ui.view">
        <field name="name">mosque.supervision.form</field>
        <field name="model">mosque.supervision</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit Report"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-success"
                            invisible="state != 'submitted'"
                            groups="waqf_mosque_rehab.group_mosque_consultant"/>
                    <button name="action_reset" string="Reset to Draft"
                            type="object" invisible="state == 'approved'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="mosque_id"/>
                            <field name="engineer_id"/>
                            <field name="report_date"/>
                            <field name="report_type"/>
                        </group>
                        <group string="Validation">
                            <field name="gps_validated" widget="boolean_toggle"/>
                            <field name="qr_validated" widget="boolean_toggle"/>
                            <field name="distance_to_site"/>
                            <field name="is_within_geofence" widget="boolean_toggle"/>
                            <field name="live_stream_url" widget="url"
                                   placeholder="https://youtube.com/live/..."/>
                        </group>
                    </group>
                    <group string="Site Conditions">
                        <field name="weather"/>
                        <field name="workers_on_site"/>
                        <field name="equipment_count"/>
                        <field name="safety_incidents"/>
                        <field name="ncr_count"/>
                        <field name="itp_hold_points_checked"/>
                        <field name="itp_hold_points_approved"/>
                    </group>
                    <notebook>
                        <page string="Activities">
                            <field name="activities_done" placeholder="Describe completed activities..."/>
                            <separator string="Planned for Next Period"/>
                            <field name="activities_planned"/>
                            <separator string="Issues &amp; Obstacles"/>
                            <field name="issues"/>
                            <separator string="Recommendations"/>
                            <field name="recommendations"/>
                        </page>
                        <page string="BOQ Progress Update">
                            <field name="boq_progress_ids">
                                <list editable="bottom">
                                    <field name="boq_id" domain="[('mosque_id','=',parent.mosque_id)]"/>
                                    <field name="description" readonly="1"/>
                                    <field name="previous_qty" readonly="1"/>
                                    <field name="this_period_qty"/>
                                    <field name="cumulative_qty" readonly="1"/>
                                    <field name="progress_pct" widget="progressbar" readonly="1"/>
                                    <field name="remarks"/>
                                </list>
                            </field>
                        </page>
                        <page string="Photos">
                            <field name="photo_ids" widget="many2many_binary"/>
                            <field name="photo_360_url"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_supervision_list" model="ir.ui.view">
        <field name="name">mosque.supervision.list</field>
        <field name="model">mosque.supervision</field>
        <field name="arch" type="xml">
            <list decoration-warning="state == 'submitted'" decoration-success="state == 'approved'">
                <field name="name"/>
                <field name="mosque_id"/>
                <field name="engineer_id"/>
                <field name="report_date"/>
                <field name="report_type"/>
                <field name="gps_validated" widget="boolean_toggle"/>
                <field name="qr_validated"  widget="boolean_toggle"/>
                <field name="ncr_count"/>
                <field name="safety_incidents"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_mosque_supervision" model="ir.actions.act_window">
        <field name="name">Supervision Reports</field>
        <field name="res_model">mosque.supervision</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_state': 'submitted'}</field>
    </record>

    <!-- ══ CERTIFICATE ════════════════════════════════════════ -->
    <record id="view_certificate_form" model="ir.ui.view">
        <field name="name">mosque.certificate.form</field>
        <field name="model">mosque.certificate</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_to_consultant" string="Submit to Consultant"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_consultant_approve" string="Consultant Approve"
                            type="object" class="btn-success"
                            invisible="state != 'consultant_review'"
                            groups="waqf_mosque_rehab.group_mosque_consultant"/>
                    <button name="action_submit_to_waqf" string="Submit to Waqf"
                            type="object" class="btn-primary"
                            invisible="state != 'consultant_approved'"
                            groups="waqf_mosque_rehab.group_mosque_consultant"/>
                    <button name="action_waqf_approve" string="Final Waqf Approval"
                            type="object" class="btn-success"
                            invisible="state != 'waqf_review'"
                            groups="waqf_mosque_rehab.group_mosque_waqf_manager"/>
                    <button name="action_mark_paid" string="Mark as Paid"
                            type="object" class="btn-info"
                            invisible="state != 'waqf_approved'"
                            groups="waqf_mosque_rehab.group_mosque_waqf_manager"/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="state in ['draft','paid','rejected']"/>
                    <button name="action_reset_to_draft" string="Reset"
                            type="object" invisible="state not in ['rejected','consultant_review']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,consultant_review,consultant_approved,waqf_review,waqf_approved,paid"/>
                </header>
                <sheet>
                    <div class="o_field_widget o_stat_buttons">
                        <div class="o_stat_button">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="certified_amount" widget="monetary"/>
                                </span>
                                <span class="o_stat_text">Payment value</span>
                            </div>
                        </div>
                        <div class="o_stat_button">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="net_payable" widget="monetary"/>
                                </span>
                                <span class="o_stat_text">Net Payable</span>
                            </div>
                        </div>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="mosque_id"/>
                            <field name="cert_number"/>
                            <field name="period_from"/>
                            <field name="period_to"/>
                            <field name="submission_date"/>
                        </group>
                        <group string="Financial">
                            <field name="certified_amount" widget="monetary"/>
                            <field name="retention_pct"/>
                            <field name="retention_amount" widget="monetary"/>
                            <field name="advance_deduction" widget="monetary"/>
                            <field name="net_payable" widget="monetary"/>
                        </group>
                    </group>

                    <group string="Approval Trail" invisible="state == 'draft'">
                        <field name="consultant_reviewer_id"/>
                        <field name="consultant_approved_date"/>
                        <field name="waqf_reviewer_id"/>
                        <field name="waqf_approved_date"/>
                        <field name="paid_date"/>
                    </group>

                    <field name="line_ids">
                        <list editable="bottom" string="BOQ Items">
                            <field name="boq_id" domain="[('mosque_id','=',parent.mosque_id)]"/>
                            <field name="description" readonly="1"/>
                            <field name="uom" readonly="1"/>
                            <field name="unit_price" readonly="1"/>
                            <field name="contracted_qty" readonly="1"/>
                            <field name="previous_qty" readonly="1"/>
                            <field name="this_period_qty"/>
                            <field name="cumulative_qty" readonly="1"/>
                            <field name="this_period_value" readonly="1" sum="Total"/>
                            <field name="cumulative_pct" widget="progressbar" readonly="1"/>
                        </list>
                    </field>

                    <field name="notes" placeholder="Internal notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_certificate_list" model="ir.ui.view">
        <field name="name">mosque.certificate.list</field>
        <field name="model">mosque.certificate</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'waqf_approved'"
                  decoration-info="state == 'paid'"
                  decoration-warning="state in ['consultant_review','waqf_review']"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="mosque_id"/>
                <field name="cert_number"/>
                <field name="period_from"/>
                <field name="period_to"/>
                <field name="certified_amount" sum="Total"/>
                <field name="retention_amount" sum="Total"/>
                <field name="net_payable" sum="Total"/>
                <field name="state" widget="badge"/>
                <field name="waqf_approved_date"/>
            </list>
        </field>
    </record>

    <record id="action_mosque_certificate" model="ir.actions.act_window">
        <field name="name">Payment Certificates</field>
        <field name="res_model">mosque.certificate</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ══ CHANGE ORDER ════════════════════════════════════════ -->
    <record id="action_change_order" model="ir.actions.act_window">
        <field name="name">Change Orders</field>
        <field name="res_model">mosque.change.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ══ ATTENDANCE ══════════════════════════════════════════ -->
    <record id="action_mosque_attendance" model="ir.actions.act_window">
        <field name="name">Field Visit Logs</field>
        <field name="res_model">mosque.attendance</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
