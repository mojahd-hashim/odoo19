<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="tmpl_dashboard" name="Waqf Executive Dashboard">
  <t t-call="web.layout">
    <t t-set="head">
      <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
      <link rel="stylesheet" href="/waqf_dashboard/static/src/css/dashboard.css"/>
      <script>
        window.WAQF_DASH_CONFIG = <t t-out="json.dumps(config)"/>;
      </script>
    </t>
    <body class="waqf-dashboard">

    <div class="wd-shell">

      <!-- ══ SIDEBAR ════════════════════════════════════════ -->
      <div class="wd-sidebar">

        <!-- Brand / Company -->
        <div class="sb-brand">
          <div class="sb-logo">
            <t t-if="company.logo">
              <img t-att-src="'data:image/png;base64,' + company.logo.decode()" alt="logo"/>
            </t>
            <t t-else="">
              <div class="sb-logo-text">و</div>
            </t>
          </div>
          <div class="sb-brand-text">
            <div class="sb-company" t-esc="company.name"/>
            <div class="sb-tagline">لوحة إدارة مشاريع التأهيل</div>
          </div>
        </div>

        <!-- Packages (loaded via JS) -->
        <div class="sb-section">المشاريع</div>
        <div id="sb-packages"></div>

        <!-- On-site summary -->
        <div class="sb-section">في الموقع الآن</div>
        <div style="padding:0 10px;margin-bottom:8px">
          <t t-foreach="on_site" t-as="person">
            <div class="sb-mosque ok" style="cursor:default">
              <div class="sb-mosque-dot" style="background:#2ECC8A"/>
              <span t-esc="person['name'][:16]"/>
              <span class="sb-mosque-code" t-esc="person['code']"/>
            </div>
          </t>
          <t t-if="not on_site">
            <div style="padding:6px 10px;font-size:10px;color:rgba(255,255,255,.25)">
              لا يوجد مستشارون في المواقع
            </div>
          </t>
        </div>

        <!-- Footer -->
        <div class="sb-footer">
          <div class="sb-user">
            <div class="sb-avatar">
              <t t-esc="(user.name or 'م')[0]"/>
            </div>
            <div class="sb-username" t-esc="user.name"/>
          </div>
        </div>
      </div>

      <!-- ══ MAIN ════════════════════════════════════════════ -->
      <div class="wd-main">

        <!-- Topbar -->
        <div class="wd-topbar">
          <div>
            <div class="topbar-title" id="topbar-title">نظرة عامة — مشروع تأهيل المساجد</div>
            <div class="topbar-sub" id="topbar-sub">
              <t t-esc="company.name"/> · 29 مسجداً وجامعاً
            </div>
          </div>
          <div class="topbar-right">

            <!-- Live stream pill -->
            <div class="live-pill" id="live-pill"
                 style="display:none"
                 title="انقر لمشاهدة البث">
              <div class="live-dot"/>
              <span>بث مباشر</span>
            </div>

            <!-- On-site pill -->
            <div class="onsite-pill" onclick="document.getElementById('modal-onsite').classList.add('show')">
              <div class="onsite-pulse"/>
              <span id="onsite-pill">
                <span>0 في الموقع</span>
              </span>
            </div>

            <a href="/dashboard/settings" class="btn btn-ghost">⚙ الإعدادات</a>
            <button class="btn btn-primary" onclick="window.location.reload()">↺ تحديث</button>
          </div>
        </div>

        <!-- ══ CONTENT ══════════════════════════════════════ -->
        <div class="wd-content">

          <!-- KPI Summary -->
          <div class="kpi-grid">
            <div class="kpi-card teal">
              <div class="kpi-label">إجمالي قيمة العقود</div>
              <div class="kpi-value"><span>ر</span><span id="kpi-total-value">—</span></div>
              <div class="kpi-sub neutral">29 مسجداً وجامعاً</div>
            </div>
            <div class="kpi-card gold">
              <div class="kpi-label">متوسط KPI الكلي</div>
              <div class="kpi-value"><span id="kpi-avg-kpi">—</span></div>
              <div class="kpi-sub neutral">الإنجاز المالي: <span id="kpi-financial-pct">—</span></div>
            </div>
            <div class="kpi-card red">
              <div class="kpi-label">مساجد متأخرة</div>
              <div class="kpi-value"><span id="kpi-delayed">—</span><span>مسجد</span></div>
              <div class="kpi-sub down">تجاوزت الجدول الزمني</div>
            </div>
            <div class="kpi-card orange">
              <div class="kpi-label">مستخلصات بانتظار الاعتماد</div>
              <div class="kpi-value"><span id="kpi-pending-cert">—</span><span>مستخلص</span></div>
              <div class="kpi-sub neutral">من الوقف</div>
            </div>
          </div>

          <!-- Gantt + Heatmap -->
          <div class="grid-2-1">
            <div class="card">
              <div class="card-hdr">
                <div class="card-title">المخطط الزمني للمشروع</div>
                <span style="font-size:10px;color:var(--text3)">اضغط على حزمة لعرض التفاصيل والانحراف</span>
              </div>
              <div class="card-body" style="overflow-x:auto">
                <div class="gantt-months" id="gantt-months" style="margin-right:130px;display:flex"/>
                <div id="gantt-rows"/>
              </div>
            </div>

            <div class="card">
              <div class="card-hdr">
                <div class="card-title">خريطة أداء المساجد</div>
              </div>
              <div class="card-body">
                <div class="hm-grid" id="heatmap-grid"/>
                <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:10px;font-size:10px;color:var(--text3)">
                  <span><span style="display:inline-block;width:8px;height:8px;background:var(--green);border-radius:2px;margin-left:3px"></span>جيد ≥70%</span>
                  <span><span style="display:inline-block;width:8px;height:8px;background:var(--orange);border-radius:2px;margin-left:3px"></span>50-70%</span>
                  <span><span style="display:inline-block;width:8px;height:8px;background:var(--red);border-radius:2px;margin-left:3px"></span>أقل من 50%</span>
                  <span><span style="display:inline-block;width:8px;height:8px;background:#C8D4DC;border-radius:2px;margin-left:3px"></span>لم يبدأ</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Mosque Detail Section -->
          <div id="section-mosque" class="wd-section">
            <div id="mosque-detail-content">
              <div style="padding:60px;text-align:center;color:var(--text3)">
                <div style="font-size:32px;margin-bottom:12px">🕌</div>
                <div style="font-size:14px;font-weight:600">اختر مسجداً من القائمة الجانبية</div>
                <div style="font-size:12px;margin-top:4px">أو انقر على أي مربع في خريطة الأداء</div>
              </div>
            </div>
          </div>

        </div><!-- /wd-content -->
      </div><!-- /wd-main -->
    </div><!-- /wd-shell -->

    <!-- ══ MODALS ════════════════════════════════════════════ -->

    <!-- Subtask Detail Modal -->
    <div class="modal-overlay" id="modal-subtask">
      <div class="modal">
        <div class="modal-hdr">
          <div class="modal-title" id="modal-subtask-title">تفاصيل المهمة الفرعية</div>
          <button class="modal-close" onclick="closeModal('modal-subtask')">✕</button>
        </div>
        <div class="modal-body" id="modal-subtask-body"></div>
      </div>
    </div>

    <!-- Photo Lightbox Modal -->
    <div class="modal-overlay" id="modal-lightbox">
      <div class="modal" style="max-width:90%;background:transparent;box-shadow:none">
        <div style="text-align:center">
          <img id="lightbox-img" style="max-width:100%;max-height:80vh;border-radius:10px" src="" alt=""/>
          <div id="lightbox-caption" style="color:#fff;margin-top:10px;font-size:13px"></div>
          <button onclick="closeModal('modal-lightbox')"
                  style="margin-top:12px;background:rgba(255,255,255,.2);color:#fff;border:none;
                         border-radius:7px;padding:8px 20px;cursor:pointer;font-size:13px">إغلاق</button>
        </div>
      </div>
    </div>

    <!-- Visit Detail Modal -->
    <div class="modal-overlay" id="modal-visit">
      <div class="modal">
        <div class="modal-hdr">
          <div class="modal-title" id="modal-visit-title">تقرير الزيارة</div>
          <button class="modal-close" onclick="closeModal('modal-visit')">✕</button>
        </div>
        <div class="modal-body" id="modal-visit-body"></div>
      </div>
    </div>

    <!-- On-site Panel Modal -->
    <div class="modal-overlay" id="modal-onsite">
      <div class="modal" style="max-width:400px">
        <div class="modal-hdr">
          <div class="modal-title">المستشارون في المواقع الآن</div>
          <button class="modal-close" onclick="closeModal('modal-onsite')">✕</button>
        </div>
        <div class="modal-body">
          <div class="onsite-list" id="onsite-list">
            <div style="text-align:center;padding:20px;color:var(--text3)">جاري التحميل...</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Live Stream Modal -->
    <div class="modal-overlay" id="modal-stream">
      <div class="modal" style="max-width:850px">
        <div class="modal-hdr">
          <div class="modal-title" id="stream-modal-title">بث مباشر</div>
          <span style="font-size:11px;color:var(--red);font-weight:700;animation:livePulse 1.5s infinite">● مباشر</span>
          <button class="modal-close" onclick="closeModal('modal-stream');document.getElementById('stream-embed').innerHTML=''">✕</button>
        </div>
        <div class="modal-body" style="padding:0">
          <div class="stream-embed" id="stream-embed"></div>
          <div style="padding:14px 16px;font-size:11px;color:var(--text3)">
            البث من الموقع الميداني — مباشر
          </div>
        </div>
      </div>
    </div>

    <!-- ══ FLOATING CHATBOT ══════════════════════════════════ -->
    <div class="chatbot-fab" id="chatbot-fab" title="مساعد الوقف الذكي">
      🤖
      <div class="chatbot-fab-dot"/>
    </div>

    <div class="chatbot-panel" id="chatbot-panel">
      <div class="chat-hdr">
        <div class="chat-av">AI</div>
        <div>
          <div class="chat-hdrtitle">مساعد الوقف الذكي</div>
        </div>
        <div class="chat-online"/>
        <span style="font-size:10px;color:var(--text3)">Azure OpenAI</span>
        <button class="chat-close" id="chat-close">✕</button>
      </div>
      <div class="chat-msgs" id="chat-msgs">
        <div class="chat-msg bot">
          مرحباً، أنا مساعدك الذكي لمتابعة مشروع تأهيل المساجد.
          اختر مسجداً من القائمة وسأعطيك تحليلاً فورياً.
        </div>
      </div>
      <div class="chat-sugs">
        <button class="chat-sug">ما المهام المتأخرة؟</button>
        <button class="chat-sug">المستخلصات المعلقة؟</button>
        <button class="chat-sug">مقارنة KPI بالخطة؟</button>
        <button class="chat-sug">آخر زيارات الاستشاري؟</button>
      </div>
      <div class="chat-input-row">
        <input class="chat-input" id="chat-input" placeholder="اسأل عن أي مشروع..." autocomplete="off"/>
        <button class="chat-send" id="chat-send">إرسال</button>
      </div>
    </div>

    <script src="/waqf_dashboard/static/src/js/dashboard.js"/>
    </body>
  </t>
</template>
</odoo>