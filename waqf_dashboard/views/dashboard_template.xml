<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="tmpl_dashboard" name="Waqf Executive Dashboard v3">
<t t-call="web.layout">
<t t-set="head">
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="stylesheet" href="/waqf_dashboard/static/src/css/dashboard.css"/>
  <style>
    .sb-nav-section{padding:10px 14px 6px;font-size:9px;font-weight:700;color:rgba(255,255,255,0.2);letter-spacing:1.2px;text-transform:uppercase}
    .pkg-card{margin:6px 10px;border-radius:14px;overflow:hidden;border:1px solid rgba(255,255,255,0.07);transition:.22s;cursor:pointer}
    .pkg-card:hover{border-color:rgba(255,255,255,0.15)}
    .pkg-card.expanded{border-color:rgba(35,114,146,0.5);box-shadow:0 0 0 2px rgba(35,114,146,0.2)}
    .pkg-card-current{background:rgba(35,114,146,0.18)}
    .pkg-card-past{background:rgba(46,204,138,0.10)}
    .pkg-card-future{background:rgba(255,255,255,0.04)}
    .pkg-card-header{display:flex;align-items:center;gap:10px;padding:12px 14px}
    .pkg-card-indicator{width:10px;height:10px;border-radius:50%;flex-shrink:0}
    .pkg-card-info{flex:1;min-width:0}
    .pkg-card-code{font-size:9px;font-weight:700;color:rgba(255,255,255,0.4);letter-spacing:0.5px;margin-bottom:2px}
    .pkg-card-name{font-size:12px;font-weight:700;color:rgba(255,255,255,0.85);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .pkg-card-live-badge{font-size:9px;font-weight:800;color:#2ECC8A;background:rgba(46,204,138,0.15);padding:2px 8px;border-radius:999px;animation:livePulse 2s infinite;flex-shrink:0}
    .pkg-card-done-badge{font-size:9px;font-weight:700;color:rgba(46,204,138,0.7);flex-shrink:0}
    .pkg-card-stats{display:flex;gap:0;border-top:1px solid rgba(255,255,255,0.06);padding:8px 14px}
    .pkg-card-stat{flex:1;text-align:center}
    .pkg-card-stat-val{font-size:16px;font-weight:800;color:#fff;line-height:1}
    .pkg-card-stat-lbl{font-size:9px;color:rgba(255,255,255,0.3);margin-top:2px}
    .pkg-card-progress{height:3px;background:rgba(255,255,255,0.08);margin:0 14px 10px;border-radius:2px;overflow:hidden}
    .pkg-card-progress-fill{height:100%;border-radius:2px;transition:width 1s ease}
    .pkg-card-mosques{border-top:1px solid rgba(255,255,255,0.06);padding:6px 8px;max-height:220px;overflow-y:auto}
    .pkg-card-mosques::-webkit-scrollbar{width:3px}
    .pkg-card-mosques::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1)}
    .pkg-mosque-item{display:flex;align-items:center;gap:7px;padding:6px 8px;border-radius:8px;cursor:pointer;transition:.12s}
    .pkg-mosque-item:hover{background:rgba(255,255,255,0.07)}
    .pkg-mosque-item.active{background:rgba(35,114,146,0.3)}
    .pkg-mosque-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
    .pkg-mosque-name{flex:1;font-size:11px;color:rgba(255,255,255,0.65);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .pkg-mosque-kpi{font-size:10px;font-weight:700;flex-shrink:0}
    .merged-tab{padding:8px 16px;font-size:11px;font-weight:700;color:var(--text3);border:none;background:none;cursor:pointer;font-family:inherit;border-bottom:2px solid transparent;margin-bottom:-2px;transition:color .15s}
    .merged-tab:hover{color:var(--text1)}
    .merged-tab.active{color:var(--primary);border-bottom-color:var(--primary)}
    .merged-panel-content{display:none}
    .merged-panel-content.active{display:block}
    #mosque-map{width:100%;height:380px;border-radius:var(--r-lg);overflow:hidden;z-index:0}
    .leaflet-popup-content-wrapper{border-radius:16px!important;box-shadow:0 8px 30px rgba(0,0,0,0.15)!important;font-family:'IBM Plex Sans Arabic',sans-serif!important}
    .leaflet-popup-content{margin:14px!important;direction:rtl}
    .leaflet-popup-tip{display:none}
    .leaflet-control-zoom a{background:rgba(27,58,82,0.9)!important;color:#fff!important;border-color:rgba(255,255,255,0.1)!important}
    @keyframes livePulse{0%,100%{opacity:1}50%{opacity:0.5}}
  </style>
  <div id="waqf-data" style="display:none"
       t-att-data-config="json.dumps(config)"
       t-att-data-packages="packages_json"
       t-att-data-summary="json.dumps(summary)"
       t-att-data-onsite="json.dumps(on_site)"
       t-att-data-has-ai="'1' if has_ai_module else '0'"/>
</t>
<body class="waqf-dashboard">
<div class="wd-shell">

  <!-- SIDEBAR -->
  <div class="wd-sidebar">
    <div class="sb-brand">
      <div class="sb-logo">
        <t t-if="company and company.logo">
          <img t-att-src="'/web/image/res.company/%d/logo' % company.id"
               t-att-alt="company.name"/>
        </t>
        <t t-else=""><span class="sb-logo-fallback">و</span></t>
      </div>
      <div class="sb-brand-text">
        <div class="sb-brand-name" t-esc="company.name"/>
        <div class="sb-brand-tag">لوحة إدارة التأهيل</div>
      </div>
    </div>
    <div class="sb-nav-section">المراحل</div>
    <div id="sb-packages"/>
    <div class="sb-nav-section">في الموقع الآن</div>
    <div style="padding:0 10px 8px">
      <t t-foreach="on_site" t-as="p">
        <div class="sb-mosque" style="cursor:default">
          <div class="sb-mosque-dot" style="background:#2ECC8A"/>
          <span class="sb-mosque-name"><t t-esc="(p.get('name') or '')[:16]"/></span>
          <span class="sb-mosque-code" t-esc="p.get('code','')"/>
        </div>
      </t>
      <t t-if="not on_site">
        <div style="padding:6px 10px;font-size:10px;color:rgba(255,255,255,.2)">
          لا يوجد مستشارون في المواقع
        </div>
      </t>
    </div>
    <div class="sb-footer">
      <div class="sb-user">
        <div class="sb-avatar"><t t-esc="(user.name or 'م')[0]"/></div>
        <div class="sb-username" t-esc="user.name"/>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="wd-main">

    <!-- Topbar -->
    <div class="wd-topbar">
      <div class="topbar-breadcrumb">
        <div class="topbar-page" id="topbar-title">نظرة عامة</div>
        <div class="topbar-sep">·</div>
        <div class="topbar-sub" id="topbar-sub">
          <t t-esc="company.name"/> · <t t-esc="mosque_count"/> مسجداً وجامعاً
        </div>
      </div>
      <div class="search-wrap">
        <input id="global-search" class="tb-search" type="text"
               placeholder="بحث عن مسجد أو مشروع..." autocomplete="off"/>
        <div id="search-dropdown" class="search-dropdown"/>
      </div>
      <div class="topbar-actions">
        <div class="tb-badge live" id="live-pill" style="display:none">
          <div class="tb-live-dot"/>
          <span>بث مباشر</span>
        </div>
        <div class="tb-badge success" style="cursor:pointer"
             onclick="document.getElementById('modal-onsite').classList.add('show')">
          <span id="onsite-count-badge"><t t-esc="on_site_count"/> في الموقع</span>
        </div>
        <t t-if="summary.get('pending_certs', 0) > 0">
          <div class="tb-badge danger">📋 <t t-esc="summary.get('pending_certs')"/></div>
        </t>
        <t t-if="summary.get('pending_cos', 0) > 0">
          <div class="tb-badge warning">🔄 <t t-esc="summary.get('pending_cos')"/></div>
        </t>
        <button class="tb-btn primary" onclick="window.location.reload()">↺</button>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="wd-content">

      <!-- KPI STRIP -->
      <div class="exec-strip">
        <div class="exec-kpi primary">
          <div class="exec-kpi-label">إجمالي قيمة المشاريع</div>
          <div class="exec-kpi-value"><span id="kpi-total-value">10</span><span class="unit">م ر</span></div>
          <div class="exec-kpi-trend flat" id="kpi-total-trend"><span class="arrow">→</span></div>
        </div>
        <div class="exec-kpi gold">
          <div class="exec-kpi-label">نسبة التقدم</div>
          <div class="exec-kpi-value"><span id="kpi-avg-kpi">—</span><span class="unit">%</span></div>
          <div class="exec-kpi-trend flat" id="kpi-avg-trend"><span class="arrow">→</span></div>
        </div>
<!--        <div class="exec-kpi warning">-->
<!--          <div class="exec-kpi-label">إجمالي التأخير</div>-->
<!--          <div class="exec-kpi-value"><span id="kpi-total-delay">—</span><span class="unit">يوم</span></div>-->
<!--          <div class="exec-kpi-trend flat" id="kpi-delay-trend"><span class="arrow">→</span></div>-->
<!--        </div>-->
        <div class="exec-kpi purple">
          <div class="exec-kpi-label">قيمة أوامر التغيير</div>
          <div class="exec-kpi-value"><span id="kpi-co-value">60</span><span class="unit">ألف</span></div>
          <div class="exec-kpi-trend flat"><span class="arrow">→</span></div>
        </div>
        <div class="exec-kpi navy">
          <div class="exec-kpi-label">اعتمادات معلّقة</div>
          <div class="exec-kpi-value" id="kpi-pending">—</div>
          <div class="exec-kpi-trend flat" id="kpi-pending-trend"><span class="arrow">→</span></div>
        </div>
        <div class="exec-kpi green">
          <div class="exec-kpi-label">مشاريع في الموعد</div>
          <div class="exec-kpi-value" id="kpi-ontime">3</div>
          <div class="exec-kpi-trend up"><span class="arrow">↑</span> جيد</div>
        </div>
          <div class="exec-kpi danger">
          <div class="exec-kpi-label">مشاريع حرجة</div>
          <div class="exec-kpi-value" id="kpi-critical">1</div>
          <div class="exec-kpi-trend flat" id="kpi-critical-trend"><span class="arrow">→</span></div>
        </div>
      </div>


      <!-- GANTT + HEATMAP -->
      <div class="grid-2">
        <div class="card accent-primary">
          <div class="card-hdr">
            <div class="card-title"><span class="card-title-icon">📅</span>المخطط الزمني — المراحل النشطة</div>
            <span style="font-size:9px;color:var(--text3)">المراحل الجارية فقط</span>
          </div>
          <div class="card-body" style="overflow-x:auto">
            <div id="gantt-months" class="gantt-months"/>
            <div id="gantt-rows"/>
          </div>
        </div>
        <div class="card accent-green">
          <div class="card-hdr">
            <div class="card-title"><span class="card-title-icon">🗺</span>خريطة أداء المساجد</div>
          </div>
          <div class="card-body">
            <div class="qf-row">
              <button class="qf-btn active" data-filter="all">الكل</button>
              <button class="qf-btn" data-filter="ok">جيد</button>
              <button class="qf-btn" data-filter="warn">متوسط</button>
              <button class="qf-btn" data-filter="critical">ضعيف</button>
              <button class="qf-btn" data-filter="delayed">متأخر</button>
            </div>
            <div class="hm-grid" id="heatmap-grid"/>
            <div style="display:flex;gap:10px;margin-top:9px;flex-wrap:wrap;font-size:9px;color:var(--text3)">
              <span><span style="display:inline-block;width:8px;height:8px;background:var(--green);border-radius:2px;margin-left:3px"/>≥70%</span>
              <span><span style="display:inline-block;width:8px;height:8px;background:var(--orange);border-radius:2px;margin-left:3px"/>50-70%</span>
              <span><span style="display:inline-block;width:8px;height:8px;background:var(--red);border-radius:2px;margin-left:3px"/>أقل 50%</span>
              <span><span style="display:inline-block;width:8px;height:8px;background:#B0C0CC;border-radius:2px;margin-left:3px"/>لم يبدأ</span>
            </div>
          </div>
        </div>
      </div>

      <!-- INTERACTIVE MAP -->
      <div class="card" style="margin-bottom:14px">
        <div class="card-hdr">
          <div class="card-title"><span class="card-title-icon">🌍</span>الخريطة التفاعلية — توزيع المساجد</div>
          <div class="card-hdr-actions">
            <span style="font-size:9px;color:var(--text3)">🔴 بث مباشر &#160; 🟠 تنبيه &#160; 🟢 جيد</span>
          </div>
        </div>
        <div class="card-body" style="padding:0">
          <div id="mosque-map">&#160;</div>
        </div>
      </div>

      <!-- RISK MATRIX + CONTRACTORS -->
      <div class="grid-2">
        <div class="card accent-gold">
          <div class="card-hdr">
            <div class="card-title"><span class="card-title-icon">⚖️</span>مصفوفة المخاطر</div>
            <span style="font-size:9px;color:var(--text3)">احتمالية × تأثير</span>
          </div>
          <div class="card-body">
            <div style="display:flex;justify-content:space-between;font-size:9px;color:var(--text3);margin-bottom:4px">
              <span>احتمالية ↑</span><span>تأثير →</span>
            </div>
            <div class="risk-matrix-wrap" id="risk-matrix">
              <div class="risk-q q1">خطر عالٍ</div>
              <div class="risk-q q2" style="align-items:flex-end;justify-content:flex-end">حرج</div>
              <div class="risk-q q3">منخفض</div>
              <div class="risk-q q4" style="justify-content:flex-end">متوسط</div>
              <div style="position:absolute;top:0;bottom:0;left:50%;width:1px;background:var(--border)"/>
              <div style="position:absolute;right:0;left:0;top:50%;height:1px;background:var(--border)"/>
              <div id="risk-dots"/>
            </div>
          </div>
        </div>
        <div class="card" style="">
          <!-- SMART ALERT CENTER -->
      <div class="alert-center" style="margin-bottom:14px">
        <div class="alert-center-hdr">
          <div class="alert-center-title">
            🚨 مركز التنبيهات الذكي
            <span class="alert-count-badge" id="alert-count">—</span>
          </div>
          <div class="alert-filters">
            <button class="alert-filter active" data-filter="all">الكل</button>
            <button class="alert-filter" data-filter="critical">حرج</button>
            <button class="alert-filter" data-filter="financial">مالي</button>
            <button class="alert-filter" data-filter="delay">تأخير</button>
            <button class="alert-filter" data-filter="quality">جودة</button>
          </div>
          <span id="alert-source-badge" style="font-size:9px;color:var(--text3);margin-right:auto"/>
        </div>
        <div class="alert-list" id="alert-list">
          <div style="padding:20px;text-align:center;color:var(--text3)">
            <div class="loading-spinner" style="width:18px;height:18px;margin:0 auto 8px"/>
            جاري تحميل التنبيهات...
          </div>
        </div>
      </div>

        </div>
  <!-- MERGED: AI + Quality + Forecast -->
<!--      <div class="card" style="margin-bottom:14px">-->
<!--        <div class="card-hdr">-->
<!--          <div class="card-title"><span class="card-title-icon">🤖</span>مركز التحليل الذكي</div>-->
<!--          <span id="ai-last-updated" style="font-size:9px;color:var(&#45;&#45;text3)"/>-->
<!--        </div>-->
<!--        <div class="card-body" id="merged-panel">-->
<!--          <div style="padding:20px;text-align:center;color:var(&#45;&#45;text3)">-->
<!--            <div class="loading-spinner" style="width:20px;height:20px;margin:0 auto 8px"/>-->
<!--            جاري تحليل البيانات...-->
<!--          </div>-->
<!--        </div>-->
<!--      </div>-->
      </div>



      <!-- MOSQUE DETAIL -->
      <div id="section-mosque">
        <div id="mosque-detail-content">
          <div style="padding:60px;text-align:center;color:var(--text3);background:var(--surface);border-radius:var(--r-xl);border:1px solid var(--border)">
            <div style="font-size:36px;margin-bottom:12px">🕌</div>
            <div style="font-size:14px;font-weight:700">اختر مسجداً من القائمة أو الخريطة</div>
            <div style="font-size:12px;margin-top:4px;color:var(--text3)">أو استخدم البحث في الأعلى</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- MODALS -->
<div class="modal-overlay" id="modal-subtask">
  <div class="modal">
    <div class="modal-hdr">
      <div class="modal-title" id="modal-subtask-title">تفاصيل المهمة</div>
      <button class="modal-close" onclick="closeModal('modal-subtask')">✕</button>
    </div>
    <div class="modal-body" id="modal-subtask-body"/>
  </div>
</div>

<div class="modal-overlay" id="modal-cert">
  <div class="modal">
    <div class="modal-hdr">
      <div class="modal-title" id="modal-cert-title">تفاصيل المستخلص</div>
      <button class="modal-close" onclick="closeModal('modal-cert')">✕</button>
    </div>
    <div class="modal-body" id="modal-cert-body"/>
  </div>
</div>

<div class="modal-overlay" id="modal-co">
  <div class="modal">
    <div class="modal-hdr">
      <div class="modal-title" id="modal-co-title">تفاصيل أمر التغيير</div>
      <button class="modal-close" onclick="closeModal('modal-co')">✕</button>
    </div>
    <div class="modal-body" id="modal-co-body"/>
  </div>
</div>

<div class="modal-overlay" id="modal-lightbox">
  <div class="modal" style="max-width:90%;background:transparent;box-shadow:none">
    <div style="text-align:center">
      <img id="lightbox-img" style="max-width:100%;max-height:80vh;border-radius:var(--r-xl)" src="" alt=""/>
      <div id="lightbox-caption" style="color:#fff;margin-top:10px;font-size:13px"/>
      <button onclick="closeModal('modal-lightbox')"
        style="margin-top:14px;background:rgba(255,255,255,.2);color:#fff;border:none;border-radius:var(--r-md);padding:9px 22px;cursor:pointer;font-size:13px">
        إغلاق
      </button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-visit">
  <div class="modal">
    <div class="modal-hdr">
      <div class="modal-title" id="modal-visit-title">تقرير الزيارة</div>
      <button class="modal-close" onclick="closeModal('modal-visit')">✕</button>
    </div>
    <div class="modal-body" id="modal-visit-body"/>
  </div>
</div>

<div class="modal-overlay" id="modal-onsite">
  <div class="modal" style="max-width:400px">
    <div class="modal-hdr">
      <div class="modal-title">المستشارون في المواقع الآن</div>
      <button class="modal-close" onclick="closeModal('modal-onsite')">✕</button>
    </div>
    <div class="modal-body">
      <div id="onsite-list">
        <div style="text-align:center;padding:20px;color:var(--text3)">جاري التحميل...</div>
      </div>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-stream">
  <div class="modal" style="max-width:860px">
    <div class="modal-hdr">
      <div class="modal-title" id="stream-modal-title">بث مباشر</div>
      <span style="font-size:11px;color:var(--red);font-weight:700">● مباشر</span>
      <button class="modal-close" onclick="closeModal('modal-stream')">✕</button>
    </div>
    <div class="modal-body" style="padding:0">
      <div class="stream-embed" id="stream-embed"/>
      <div style="padding:12px 18px;font-size:11px;color:var(--text3)">
        البث من الموقع الميداني عبر Cloudflare Stream
      </div>
    </div>
  </div>
</div>

<!-- CHATBOT -->
<div class="chatbot-fab" id="chatbot-fab" title="مساعد الوقف الذكي">
  🤖
  <div class="chatbot-fab-dot"/>
</div>
<div class="chatbot-panel" id="chatbot-panel">
  <div class="chat-hdr">
    <div class="chat-av">AI</div>
    <div><div class="chat-hdr-title">مساند</div></div>
    <div class="chat-online"/>
    <button class="chat-close" id="chat-close">✕</button>
  </div>
  <div class="chat-msgs" id="chat-msgs">
    <div class="chat-msg bot">مرحباً، اختر مسجداً وسأحلل بياناته فوراً.</div>
  </div>
  <div class="chat-sugs">
    <button class="chat-sug">كيف هو الاداء العام للمشروع؟</button>
    <button class="chat-sug">ما هي الأولويات التي يجب التركيز عليها في المرحلة القادمة؟</button>
    <button class="chat-sug"> ما هي الموارد الإضافية المطلوبة لتسريع الإنجاز؟</button>
  </div>
  <div class="chat-input-row">
    <input class="chat-input" id="chat-input" placeholder="اسأل عن أي مشروع..." autocomplete="off"/>
    <button class="chat-send" id="chat-send">إرسال</button>
  </div>
</div>

<script src="/waqf_dashboard/static/src/js/dashboard.js"/>
</body>
</t>
</template>
</odoo>