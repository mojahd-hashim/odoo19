<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="tmpl_live_wall" name="Live Streams Wall">
<t t-call="web.layout">
<t t-set="head">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>البثوث المباشرة</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&amp;display=swap" rel="stylesheet"/>
    <style>
        :root {
            --dark:    #0F1B2D;
            --dark2:   #16243A;
            --primary: #237292;
            --green:   #2ECC8A;
            --red:     #E74C3C;
            --gold:    #C8A430;
            --border:  rgba(255,255,255,.08);
            --t1:      #FFFFFF;
            --t2:      rgba(255,255,255,.6);
            --t3:      rgba(255,255,255,.35);
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html, body { height:100%; }
        body {
            font-family:'Cairo',sans-serif;
            background:
                radial-gradient(1200px 600px at 80% -10%, rgba(35,114,146,.18), transparent 60%),
                radial-gradient(900px 500px at 10% 110%, rgba(200,164,48,.08), transparent 60%),
                var(--dark);
            color:var(--t1);
            direction:rtl;
            min-height:100vh;
            overflow-x:hidden;
        }

        /* ── Header ─────────────────────────────────── */
        .lw-header {
            display:flex; align-items:center; justify-content:space-between;
            padding:18px 28px;
            border-bottom:1px solid var(--border);
            backdrop-filter:blur(8px);
            position:sticky; top:0; z-index:50;
            background:rgba(15,27,45,.85);
        }
        .lw-brand { display:flex; align-items:center; gap:14px; }
        .lw-live-dot {
            width:42px; height:42px; border-radius:12px;
            background:rgba(231,76,60,.12);
            display:flex; align-items:center; justify-content:center;
            position:relative;
        }
        .lw-live-dot::after {
            content:''; width:12px; height:12px; border-radius:50%;
            background:var(--red);
            animation:pulse 1.4s ease-in-out infinite;
        }
        @keyframes pulse {
            0%,100% { box-shadow:0 0 0 0 rgba(231,76,60,.5); }
            50%      { box-shadow:0 0 0 10px rgba(231,76,60,0); }
        }
        .lw-title { font-size:18px; font-weight:800; }
        .lw-sub   { font-size:11px; color:var(--t3); }
        .lw-count-pill {
            display:flex; align-items:center; gap:8px;
            padding:8px 16px; border-radius:999px;
            background:rgba(46,204,138,.1);
            border:1px solid rgba(46,204,138,.25);
            font-size:13px; font-weight:700; color:var(--green);
        }

        /* ── Grid ───────────────────────────────────── */
        .lw-grid {
            display:grid;
            gap:16px;
            padding:24px 28px 40px;
            grid-template-columns:repeat(3, 1fr);
            max-width:1600px;
            margin:0 auto;
        }
        @media (max-width: 1100px) { .lw-grid { grid-template-columns:repeat(2,1fr); } }
        @media (max-width: 700px)  { .lw-grid { grid-template-columns:1fr; padding:16px; } }

        /* ── Tile ───────────────────────────────────── */
        .lw-tile {
            position:relative;
            border-radius:18px;
            overflow:hidden;
            background:var(--dark2);
            border:1px solid var(--border);
            cursor:pointer;
            transition:transform .25s ease, box-shadow .25s ease, border-color .25s;
        }
        .lw-tile:hover {
            transform:translateY(-4px);
            border-color:rgba(35,114,146,.5);
            box-shadow:0 16px 40px rgba(0,0,0,.45), 0 0 0 1px rgba(35,114,146,.3);
        }
        .lw-tile-video {
            position:relative;
            aspect-ratio:16/9;
            background:#000;
        }
        .lw-tile-video iframe {
            position:absolute; inset:0;
            width:100%; height:100%; border:0;
            pointer-events:none;   /* الضغط يفتح المكبّر وليس iframe */
        }
        /* شارة LIVE */
        .lw-badge-live {
            position:absolute; top:10px; right:10px; z-index:3;
            display:flex; align-items:center; gap:6px;
            padding:4px 10px; border-radius:8px;
            background:rgba(231,76,60,.92);
            font-size:10px; font-weight:800; letter-spacing:1.2px;
        }
        .lw-badge-live::before {
            content:''; width:6px; height:6px; border-radius:50%;
            background:#fff; animation:blink 1.2s infinite;
        }
        @keyframes blink { 50% { opacity:.3; } }
        /* المشاهدون */
        .lw-badge-viewers {
            position:absolute; top:10px; left:10px; z-index:3;
            display:flex; align-items:center; gap:5px;
            padding:4px 10px; border-radius:8px;
            background:rgba(0,0,0,.55); backdrop-filter:blur(4px);
            font-size:11px; font-weight:600; color:var(--t2);
        }
        /* تدرّج + معلومات أسفل الفيديو */
        .lw-tile-info {
            padding:12px 16px 14px;
            background:linear-gradient(180deg, rgba(22,36,58,0), var(--dark2) 30%);
        }
        .lw-region {
            display:flex; align-items:center; gap:8px;
            font-size:15px; font-weight:800; margin-bottom:2px;
        }
        .lw-region svg { flex-shrink:0; opacity:.7; }
        .lw-mosque { font-size:11.5px; color:var(--t3); }
        /* أيقونة تكبير عند hover */
        .lw-expand-hint {
            position:absolute; inset:0; z-index:2;
            display:flex; align-items:center; justify-content:center;
            background:rgba(15,27,45,0);
            transition:background .25s;
        }
        .lw-expand-hint svg {
            opacity:0; transform:scale(.7);
            transition:opacity .25s, transform .25s;
            filter:drop-shadow(0 4px 12px rgba(0,0,0,.6));
        }
        .lw-tile:hover .lw-expand-hint { background:rgba(15,27,45,.35); }
        .lw-tile:hover .lw-expand-hint svg { opacity:1; transform:scale(1); }

        /* ── Empty state ────────────────────────────── */
        .lw-empty {
            grid-column:1/-1;
            text-align:center; padding:100px 20px;
        }
        .lw-empty-icon {
            width:90px; height:90px; margin:0 auto 20px;
            border-radius:50%; background:rgba(255,255,255,.04);
            display:flex; align-items:center; justify-content:center;
        }
        .lw-empty-title { font-size:17px; font-weight:700; color:var(--t2); }
        .lw-empty-sub   { font-size:12px; color:var(--t3); margin-top:6px; }

        /* ── Modal (المكبّر) ─────────────────────────── */
        .lw-modal {
            position:fixed; inset:0; z-index:100;
            display:none;
            align-items:center; justify-content:center;
            background:rgba(5,10,18,.92);
            backdrop-filter:blur(12px);
            padding:24px;
        }
        .lw-modal.open { display:flex; animation:fadeIn .25s ease; }
        @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
        .lw-modal-box {
            width:min(1200px, 96vw);
            animation:zoomIn .3s cubic-bezier(.2,.9,.3,1.2);
        }
        @keyframes zoomIn {
            from { transform:scale(.92); opacity:0; }
            to   { transform:scale(1);   opacity:1; }
        }
        .lw-modal-video {
            position:relative;
            aspect-ratio:16/9;
            border-radius:20px; overflow:hidden;
            background:#000;
            box-shadow:0 30px 80px rgba(0,0,0,.7);
            border:1px solid rgba(255,255,255,.1);
        }
        .lw-modal-video iframe {
            position:absolute; inset:0;
            width:100%; height:100%; border:0;
        }
        /* شريط التحكم */
        .lw-controls {
            display:flex; align-items:center; justify-content:space-between;
            margin-top:16px; gap:12px; flex-wrap:wrap;
        }
        .lw-modal-meta { display:flex; flex-direction:column; gap:2px; }
        .lw-modal-region { font-size:18px; font-weight:800; display:flex; align-items:center; gap:10px; }
        .lw-modal-mosque { font-size:12px; color:var(--t3); }
        .lw-btns { display:flex; gap:10px; }
        .lw-btn {
            display:flex; align-items:center; gap:8px;
            padding:11px 20px; border-radius:12px;
            border:1px solid var(--border);
            background:rgba(255,255,255,.06);
            color:var(--t1); font-family:'Cairo'; font-size:13px; font-weight:700;
            cursor:pointer; transition:background .2s, transform .15s;
        }
        .lw-btn:hover  { background:rgba(255,255,255,.12); }
        .lw-btn:active { transform:scale(.96); }
        .lw-btn.primary { background:var(--primary); border-color:transparent; }
        .lw-btn.primary:hover { background:#2B85AA; }
        .lw-btn.danger  { background:rgba(231,76,60,.15); border-color:rgba(231,76,60,.3); color:#FF8A7A; }
        .lw-btn.danger:hover { background:rgba(231,76,60,.28); }
    </style>
</t>
<body>

    <!-- ── Header ─────────────────────────────────────── -->
    <header class="lw-header">
        <div class="lw-brand">
            <div class="lw-live-dot"></div>
            <div>
                <div class="lw-title">البثوث المباشرة</div>
                <div class="lw-sub">وقف الملك عبدالله — متابعة مواقع تأهيل المساجد</div>
            </div>
        </div>
        <div class="lw-count-pill">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="7" cy="7" r="2" fill="currentColor"/>
            </svg>
            <span id="lw-count"><t t-esc="len(streams)"/></span> بث نشط
        </div>
    </header>

    <!-- ── Grid ───────────────────────────────────────── -->
    <main class="lw-grid" id="lw-grid">

        <t t-if="not streams">
            <div class="lw-empty">
                <div class="lw-empty-icon">
                    <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                        <rect x="5" y="9" width="30" height="20" rx="4"
                              stroke="rgba(255,255,255,.25)" stroke-width="2"/>
                        <path d="M14 34h12" stroke="rgba(255,255,255,.25)"
                              stroke-width="2" stroke-linecap="round"/>
                        <path d="M16 16l-4 3 4 3M24 16l4 3-4 3"
                              stroke="rgba(255,255,255,.25)" stroke-width="2"
                              stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="lw-empty-title">لا توجد بثوث مباشرة الآن</div>
                <div class="lw-empty-sub">ستظهر البثوث هنا فور بدئها من المواقع</div>
            </div>
        </t>

        <t t-foreach="streams" t-as="s">
            <div class="lw-tile"
                 t-att-data-url="s.stream_url"
                 t-att-data-region="s.mosque_id.city or s.name"
                 t-att-data-mosque="s.mosque_id.name or ''"
                 t-att-data-viewers="s.viewers or 0"
                 onclick="openModal(this)">

                <div class="lw-tile-video">
                    <span class="lw-badge-live">LIVE</span>
                    <span class="lw-badge-viewers">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                            <path d="M1 6s2-3.5 5-3.5S11 6 11 6s-2 3.5-5 3.5S1 6 1 6z"
                                  stroke="currentColor" stroke-width="1.2"/>
                            <circle cx="6" cy="6" r="1.5" stroke="currentColor" stroke-width="1.2"/>
                        </svg>
                        <t t-esc="s.viewers or 0"/>
                    </span>
                    <iframe t-att-src="s.stream_url + '?muted=true&amp;autoplay=true&amp;controls=false'"
                            allow="autoplay"
                            loading="lazy"/>
                    <div class="lw-expand-hint">
                        <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
                            <circle cx="26" cy="26" r="25" fill="rgba(35,114,146,.9)"/>
                            <path d="M20 26h12M26 20l6 6-6 6" stroke="white" stroke-width="2.5"
                                  stroke-linecap="round" stroke-linejoin="round"
                                  transform="rotate(-45 26 26)"/>
                        </svg>
                    </div>
                </div>

                <div class="lw-tile-info">
                    <div class="lw-region">
                        <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
                            <path d="M7.5 1C4.75 1 2.5 3.2 2.5 6c0 3.6 5 8 5 8s5-4.4 5-8c0-2.8-2.25-5-5-5z"
                                  stroke="var(--primary)" stroke-width="1.4"/>
                            <circle cx="7.5" cy="6" r="1.8" stroke="var(--primary)" stroke-width="1.4"/>
                        </svg>
                        <t t-esc="s.mosque_id.city or s.name"/>
                    </div>
                    <div class="lw-mosque">
                        🕌 <t t-esc="s.mosque_id.name or s.name"/>
                    </div>
                </div>
            </div>
        </t>

    </main>

    <!-- ── Modal — المشغّل المكبّر ─────────────────────── -->
    <div class="lw-modal" id="lw-modal" onclick="if(event.target===this)closeModal()">
        <div class="lw-modal-box">
            <div class="lw-modal-video" id="lw-modal-video">
                <iframe id="lw-modal-iframe" src="about:blank"
                        allow="autoplay; fullscreen; picture-in-picture"
                        allowfullscreen="allowfullscreen"/>
            </div>
            <div class="lw-controls">
                <div class="lw-modal-meta">
                    <div class="lw-modal-region">
                        <svg width="18" height="18" viewBox="0 0 15 15" fill="none">
                            <path d="M7.5 1C4.75 1 2.5 3.2 2.5 6c0 3.6 5 8 5 8s5-4.4 5-8c0-2.8-2.25-5-5-5z"
                                  stroke="#2ECC8A" stroke-width="1.4"/>
                            <circle cx="7.5" cy="6" r="1.8" stroke="#2ECC8A" stroke-width="1.4"/>
                        </svg>
                        <span id="lw-modal-region">—</span>
                    </div>
                    <div class="lw-modal-mosque" id="lw-modal-mosque">—</div>
                </div>
                <div class="lw-btns">
                    <button class="lw-btn" onclick="toggleMute()" id="lw-mute-btn">
                        <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
                            <path d="M2 5.5v4h2.5L8 12.5v-10L4.5 5.5H2z" stroke="currentColor"
                                  stroke-width="1.3" stroke-linejoin="round"/>
                            <path d="M10.5 5.5c.8.8.8 3.2 0 4" stroke="currentColor"
                                  stroke-width="1.3" stroke-linecap="round"/>
                        </svg>
                        <span id="lw-mute-label">تشغيل الصوت</span>
                    </button>
                    <button class="lw-btn primary" onclick="goFullscreen()">
                        <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
                            <path d="M2 5V2h3M13 5V2h-3M2 10v3h3M13 10v3h-3"
                                  stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                        </svg>
                        ملء الشاشة
                    </button>
                    <button class="lw-btn danger" onclick="closeModal()">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <path d="M3 3l8 8M11 3l-8 8" stroke="currentColor"
                                  stroke-width="1.6" stroke-linecap="round"/>
                        </svg>
                        إغلاق
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script><![CDATA[
        var currentUrl = '';
        var isMuted = true;

        function openModal(tile) {
            currentUrl = tile.dataset.url;
            isMuted = true;
            document.getElementById('lw-modal-region').textContent = tile.dataset.region || '—';
            document.getElementById('lw-modal-mosque').textContent =
                '🕌 ' + (tile.dataset.mosque || '') +
                '  ·  👁 ' + (tile.dataset.viewers || 0) + ' مشاهد';
            document.getElementById('lw-mute-label').textContent = 'تشغيل الصوت';
            document.getElementById('lw-modal-iframe').src =
                currentUrl + '?autoplay=true&muted=true&controls=true';
            document.getElementById('lw-modal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            document.getElementById('lw-modal').classList.remove('open');
            document.getElementById('lw-modal-iframe').src = 'about:blank';
            document.body.style.overflow = '';
        }

        function toggleMute() {
            isMuted = !isMuted;
            document.getElementById('lw-mute-label').textContent =
                isMuted ? 'تشغيل الصوت' : 'كتم الصوت';
            document.getElementById('lw-modal-iframe').src =
                currentUrl + '?autoplay=true&controls=true&muted=' + isMuted;
        }

        function goFullscreen() {
            var el = document.getElementById('lw-modal-video');
            if (el.requestFullscreen)            el.requestFullscreen();
            else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });

        // ── تحديث تلقائي كل 30 ثانية — يعيد التحميل إن تغيّر عدد البثوث ──
        var initialCount = document.querySelectorAll('.lw-tile').length;
        setInterval(function() {
            fetch('/live/wall/data', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({jsonrpc: '2.0', method: 'call', params: {}})
            })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                var streams = res.result || [];
                if (streams.length !== initialCount) location.reload();
            })
            .catch(function() {});
        }, 30000);
    ]]></script>

</body>
</t>
</template>

</odoo>