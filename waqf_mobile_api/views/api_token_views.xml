<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ══ API TOKEN FORM ════════════════════════════════════════ -->
<record id="view_api_token_form" model="ir.ui.view">
    <field name="name">waqf.api.token.form</field>
    <field name="model">waqf.api.token</field>
    <field name="arch" type="xml">
        <form string="API Token">
            <header>
                <button name="action_revoke" string="إلغاء التوكن"
                        type="object" class="btn-danger"
                        invisible="not is_active"/>
                <button name="action_generate_new" string="توليد توكن جديد"
                        type="object" class="btn-warning"
                        invisible="not is_active"/>
            </header>
            <sheet>
                <div class="alert alert-warning" invisible="is_active">
                    ⚠ هذا التوكن ملغي — لا يمكن استخدامه للدخول.
                </div>
                <group>
                    <group>
                        <field name="name"/>
                        <field name="employee_id"/>
                        <field name="token_prefix"
                               string="بداية التوكن (للتعريف)"
                               readonly="1"/>
                        <field name="is_active" widget="boolean_toggle"/>
                    </group>
                    <group>
                        <field name="expires_at"/>
                        <field name="last_used" readonly="1"/>
                        <field name="device_info" readonly="1"/>
                        <field name="is_expired" widget="boolean_toggle"
                               readonly="1"/>
                    </group>
                </group>
                <field name="fcm_token" string="FCM Push Token"
                       readonly="1"
                       help="يُحدَّث تلقائياً من التطبيق"/>
            </sheet>
        </form>
    </field>
</record>

<!-- ══ API TOKEN LIST ════════════════════════════════════════ -->
<record id="view_api_token_list" model="ir.ui.view">
    <field name="name">waqf.api.token.list</field>
    <field name="model">waqf.api.token</field>
    <field name="arch" type="xml">
        <list string="API Tokens"
              decoration-muted="not is_active or is_expired"
              decoration-success="is_active and not is_expired">
            <field name="employee_id"/>
            <field name="name"/>
            <field name="token_prefix" string="التوكن (جزء)"/>
            <field name="device_info"/>
            <field name="last_used"/>
            <field name="expires_at"/>
            <field name="is_active" widget="boolean_toggle"/>
            <field name="is_expired" widget="boolean_toggle"/>
        </list>
    </field>
</record>

<!-- ══ TOKEN SHOW WIZARD ═════════════════════════════════════ -->
<record id="view_token_show_wizard" model="ir.ui.view">
    <field name="name">waqf.token.show.wizard.form</field>
    <field name="model">waqf.token.show.wizard</field>
    <field name="arch" type="xml">
        <form string="API Token — انسخه الآن">
            <sheet>
                <div class="alert alert-danger">
                    <strong>⚠ انسخ هذا التوكن الآن</strong><br/>
                    لن يظهر مرة أخرى بعد إغلاق هذه النافذة.
                </div>
                <group>
                    <field name="raw_token" readonly="1"
                           string="API Token"
                           widget="copy_clipboard"
                           style="font-family:monospace;font-size:13px;
                                  background:#F4F8FB;padding:10px;
                                  border-radius:6px;word-break:break-all"/>
                </group>
                <div class="text-muted" style="font-size:12px;margin-top:8px">
                    أضف هذا التوكن في إعدادات التطبيق ← BASE_URL + Token
                </div>
            </sheet>
            <footer>
                <button name="action_copy_done" string="تم النسخ — أغلق"
                        type="object" class="btn-primary"/>
            </footer>
        </form>
    </field>
</record>

<!-- ══ EMPLOYEE FORM — add mobile tab ════════════════════════ -->
<record id="view_employee_form_mobile_inherit" model="ir.ui.view">
    <field name="name">hr.employee.form.mobile</field>
    <field name="model">hr.employee</field>
    <field name="inherit_id" ref="hr.view_employee_form"/>
    <field name="arch" type="xml">
        <xpath expr="//notebook" position="inside">
            <page string="📱 Mobile App" name="mobile_app">

                <!-- Quick generate button -->
                <div style="margin-bottom:16px">
                    <button name="action_generate_api_token"
                            string="🔑 توليد API Token جديد"
                            type="object" class="btn-primary btn-sm"/>
                    <span style="font-size:12px;color:#7A8F9F;margin-right:12px">
                        (<field name="active_token_count" readonly="1" nolabel="1"/>
                        توكن نشط)
                    </span>
                </div>

                <!-- Assigned mosques -->
                <group string="المساجد المكلف بها">
                    <field name="mosque_package_ids"
                           widget="many2many_tags"
                           string="الحزم الجغرافية"
                           help="تعيين حزمة يُضيف جميع مساجدها تلقائياً"/>
                    <field name="assigned_mosque_ids"
                           widget="many2many_tags"
                           string="مساجد مباشرة"/>
                    <field name="all_mosque_ids"
                           widget="many2many_tags"
                           string="إجمالي المساجد" readonly="1"/>
                </group>

                <!-- API Tokens -->
                <group string="API Tokens">
                    <field name="api_token_ids" nolabel="1">
                        <list string="Tokens"
                              decoration-muted="not is_active or is_expired"
                              decoration-success="is_active and not is_expired">
                            <field name="name"/>
                            <field name="token_prefix" string="Token"/>
                            <field name="device_info"/>
                            <field name="last_used"/>
                            <field name="expires_at"/>
                            <field name="is_active" widget="boolean_toggle"/>
                            <button name="action_revoke" type="object"
                                    string="إلغاء" class="btn-danger btn-sm"
                                    invisible="not is_active"/>
                        </list>
                    </field>
                </group>

                <!-- FCM -->
                <group string="Push Notifications">
                    <field name="fcm_token" readonly="1"
                           string="FCM Token"
                           help="يُحدَّث تلقائياً من التطبيق"/>
                </group>

            </page>
        </xpath>
    </field>
</record>

<!-- ══ ACTION ════════════════════════════════════════════════ -->
<record id="action_api_tokens" model="ir.actions.act_window">
    <field name="name">API Tokens</field>
    <field name="res_model">waqf.api.token</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'search_default_active': 1}</field>
</record>

</odoo>
