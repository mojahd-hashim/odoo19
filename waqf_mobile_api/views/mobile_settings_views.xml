<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ MOBILE SETTINGS — res.config.settings ════════════════ -->
    <record id="view_mobile_settings" model="ir.ui.view">
        <field name="name">res.config.settings.mobile</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form" position="inside">

                <app string="Mobile API" name="waqf_mobile_api">

                    <block title="📱 إعدادات تطبيق الجوال — Mobile App">

                        <!-- Geofence -->
                        <setting string="إعدادات الجيوفنس">
                            <div class="text-muted mb-3">
                                التحقق الجغرافي من وجود المستشار في الموقع
                            </div>

                            <div class="row mt16">
                                <label class="col-lg-4 o_light_label"
                                       for="waqf_default_geofence_radius">
                                    نطاق افتراضي (م)
                                </label>
                                <div class="col-lg-2">
                                    <field name="waqf_default_geofence_radius"/>
                                </div>
                            </div>

                            <div class="row mt16">
                                <label class="col-lg-4 o_light_label"
                                       for="waqf_min_visit_minutes">
                                    حد أدنى للزيارة (دقيقة)
                                </label>
                                <div class="col-lg-2">
                                    <field name="waqf_min_visit_minutes"/>
                                </div>
                            </div>

                            <div class="row mt16">
                                <label class="col-lg-4 o_light_label"
                                       for="waqf_long_stay_hours">
                                    تنبيه الإقامة الطويلة (ساعة)
                                </label>
                                <div class="col-lg-2">
                                    <field name="waqf_long_stay_hours"/>
                                </div>
                            </div>
                        </setting>

                        <!-- Auto checkin -->
                        <setting string="تسجيل حضور تلقائي صامت"
                                 help="عند التفعيل يُسجَّل الحضور بدون إشعار عند الوصول للنطاق">
                            <field name="waqf_auto_checkin"/>
                        </setting>

                        <!-- QR -->
                        <setting string="إلزامية مسح QR للحضور"
                                 help="GPS وحده لا يكفي — يجب مسح QR المثبت في المسجد">
                            <field name="waqf_require_qr"/>
                        </setting>

                        <!-- Report -->
                        <setting string="إلزامية التقرير عند الانصراف"
                                 help="المستشار يجب أن يُرسل تقرير الزيارة قبل الانصراف">
                            <field name="waqf_report_required_on_checkout"/>
                        </setting>

                        <setting string="الحد الأدنى للصور في التقرير">
                            <field name="waqf_report_min_photos"/>
                        </setting>

                        <!-- Maintenance -->
                        <setting string="وضع الصيانة"
                                 help="يوقف التطبيق ويعرض رسالة الصيانة">
                            <field name="waqf_maintenance_mode"/>
                        </setting>

                        <setting string="رسالة الصيانة">
                            <field name="waqf_maintenance_message"
                                   placeholder="رسالة تظهر للمستخدمين..."
                                   invisible="not waqf_maintenance_mode"/>
                        </setting>

                        <!-- App version -->
                        <setting string="الحد الأدنى لإصدار التطبيق"
                                 help="الإصدارات الأقدم تُجبر على التحديث">
                            <field name="waqf_app_version_min"
                                   placeholder="1.0.0"/>
                        </setting>

                    </block>

                </app>

            </xpath>

        </field>
    </record>

</odoo>