<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_ai_risk" model="ir.module.category">
        <field name="name">AI Risk Center</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_ai_risk_viewer" model="res.groups">
        <field name="name">AI Risk Viewer</field>
        <field name="category_id" ref="module_category_ai_risk"/>
    </record>

    <record id="group_ai_risk_manager" model="res.groups">
        <field name="name">AI Risk Manager</field>
        <field name="category_id" ref="module_category_ai_risk"/>
        <field name="implied_ids" eval="[(4, ref('group_ai_risk_viewer'))]"/>
    </record>

    <record id="group_ai_risk_admin" model="res.groups">
        <field name="name">AI Risk Admin</field>
        <field name="category_id" ref="module_category_ai_risk"/>
        <field name="implied_ids" eval="[(4, ref('group_ai_risk_manager'))]"/>
    </record>
</odoo>
