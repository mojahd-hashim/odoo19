<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_ai_risk" model="ir.ui.view">
        <field name="name">res.config.settings.ai.risk</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="AI Risk Center" string="AI Risk Center" name="waqf_ai_risk_center"
                     groups="waqf_mosque_ai_risk_center.group_ai_risk_admin">
                    <block title="Azure OpenAI">
                        <setting string="Enable AI Analysis">
                            <field name="waqf_ai_enabled"/>
                        </setting>
                        <setting string="Azure Endpoint">
                            <field name="waqf_ai_azure_endpoint" placeholder="https://xxxx.openai.azure.com"/>
                        </setting>
                        <setting string="Azure API Key">
                            <field name="waqf_ai_azure_api_key" password="True"/>
                        </setting>
                        <setting string="Deployment">
                            <field name="waqf_ai_azure_deployment"/>
                        </setting>
                    </block>
                    <block title="Run Settings">
                        <setting string="Run Interval Hours">
                            <field name="waqf_ai_run_interval_hours"/>
                        </setting>
                        <setting string="Max Mosques Per Run">
                            <field name="waqf_ai_max_mosques_per_run"/>
                        </setting>
                        <setting string="Confidence Threshold">
                            <field name="waqf_ai_confidence_threshold"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
