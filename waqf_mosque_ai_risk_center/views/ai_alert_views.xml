<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_alert_kanban" model="ir.ui.view">
        <field name="name">waqf.ai.alert.kanban</field>
        <field name="model">waqf.ai.alert</field>
        <field name="arch" type="xml">
            <kanban default_group_by="severity" class="o_kanban_small_column">
                <field name="title"/>
                <field name="severity"/>
                <field name="status"/>
                <field name="mosque_id"/>
                <field name="priority_score"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong>
                                <field name="title"/>
                            </strong>
                            <div>
                                <field name="mosque_id"/>
                            </div>
                            <div>Priority:
                                <field name="priority_score"/>
                            </div>
                            <field name="status" widget="badge"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="view_ai_alert_list" model="ir.ui.view">
        <field name="name">waqf.ai.alert.list</field>
        <field name="model">waqf.ai.alert</field>
        <field name="arch" type="xml">
            <list decoration-danger="severity == 'critical'" decoration-warning="severity == 'high'"
                  decoration-muted="status in ('resolved','dismissed')">
                <field name="severity"/>
                <field name="status"/>
                <field name="title"/>
                <field name="alert_type"/>
                <field name="mosque_id"/>
                <field name="contractor"/>
                <field name="confidence"/>
                <field name="priority_score"/>
                <field name="source"/>
            </list>
        </field>
    </record>
    <record id="view_ai_alert_form" model="ir.ui.view">
        <field name="name">waqf.ai.alert.form</field>
        <field name="model">waqf.ai.alert</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_acknowledge" type="object" string="Acknowledge" class="btn-primary"
                            invisible="status != 'new'" groups="waqf_mosque_ai_risk_center.group_ai_risk_manager"/>
                    <button name="action_in_progress" type="object" string="In Progress"
                            invisible="status not in ('new','acknowledged')"
                            groups="waqf_mosque_ai_risk_center.group_ai_risk_manager"/>
                    <button name="action_resolve" type="object" string="Resolve" class="btn-success"
                            groups="waqf_mosque_ai_risk_center.group_ai_risk_manager"/>
                    <button name="action_dismiss" type="object" string="Dismiss"
                            groups="waqf_mosque_ai_risk_center.group_ai_risk_manager"/>
                    <button name="action_open_mosque" type="object" string="Open Mosque" invisible="not mosque_id"/>
                    <button name="action_open_related_certificates" type="object" string="Open Related Certificates"
                            invisible="not mosque_id"/>
                    <button name="action_open_related_reports" type="object" string="Open Related Reports"
                            invisible="not mosque_id"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="title"/>
                            <field name="severity"/>
                            <field name="alert_type"/>
                            <field name="source"/>
                            <field name="mosque_id"/>
                            <field name="contractor"/>
                        </group>
                        <group>
                            <field name="confidence"/>
                            <field name="priority_score"/>
                            <field name="impact_score"/>
                            <field name="probability_score"/>
                            <field name="assigned_user_id"/>
                            <field name="due_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Summary">
                            <field name="summary"/>
                            <field name="root_cause"/>
                            <field name="impact"/>
                            <field name="phase_impact"/>
                            <field name="recommendation"/>
                        </page>
                        <page string="Related Metrics">
                            <field name="related_metrics_json" widget="json"/>
                        </page>
                        <page string="AI Payload">
                            <field name="ai_payload_json" widget="json"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_ai_alert" model="ir.actions.act_window">
        <field name="name">Smart Alerts</field>
        <field name="res_model">waqf.ai.alert</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>
