<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ══════════════════════════════════════════════════
             مجموعات المقاولين
        ══════════════════════════════════════════════════ -->

        <!-- مهندس/مشرف موقع — مساجده فقط -->
        <record id="group_contractor_site" model="res.groups">
            <field name="name">مقاول: مشرف موقع</field>
        </record>

        <!-- مشرف عام — كل مساجده المخوّلة -->
        <record id="group_contractor_admin" model="res.groups">
            <field name="name">مقاول: مشرف عام</field>
        </record>
        <record id="group_waqf_admin" model="res.groups">
            <field name="name">تأهيل المقاول :صلاحية الوقف</field>
        </record>

        <!-- استشاري — يطّلع على الكل -->
        <record id="group_consultant_all" model="res.groups">
            <field name="name">استشاري: كل المساجد</field>
        </record>
        <record id="group_site_consultant" model="res.groups">
            <field name="name">استشاري:مشرف مواقع</field>
        </record>

    </data>

    <data noupdate="0">

        <!-- ══════════════════════════════════════════════════
             RECORD RULES — أوامر العمل
        ══════════════════════════════════════════════════ -->

        <!-- ① المقاول يرى فقط أوامر مساجده المخوّلة -->
        <record id="rule_wo_contractor_own_mosques" model="ir.rule">
            <field name="name">أوامر العمل: مساجد المستشار المخوّلة فقط</field>
            <field name="model_id" ref="model_contractor_work_order"/>
            <field name="groups" eval="[(4, ref('group_site_consultant'))]"/>
            <field name="domain_force">
                ['|',
                ('portal_user_id', '=', user.id),
                ('mosque_id', 'in',
                user.waqf_portal_user_id.effective_mosque_ids.ids
                if user.waqf_portal_user_id else [])
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ② الاستشاري يرى كل أوامر العمل -->
        <record id="rule_wo_consultant_all" model="ir.rule">
            <field name="name">أوامر العمل: الاستشاري يرى الكل</field>
            <field name="model_id" ref="model_contractor_work_order"/>
            <field name="groups" eval="[(4, ref('group_consultant_all'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ══════════════════════════════════════════════════
             RECORD RULES — العينات (Submittals)
        ══════════════════════════════════════════════════ -->
        <record id="rule_sub_contractor_own" model="ir.rule">
            <field name="name">العينات: مساجد المستشار فقط</field>
            <field name="model_id" ref="model_contractor_material_submittal"/>
            <field name="groups" eval="[(4, ref('group_site_consultant'))]"/>
            <field name="domain_force">
                [
                '|',
                ('mosque_ids', 'in',
                user.waqf_portal_user_id.effective_mosque_ids.ids
                if user.waqf_portal_user_id else []),
                ('mosque_id', 'in',
                user.waqf_portal_user_id.effective_mosque_ids.ids
                if user.waqf_portal_user_id else [])
                ]
            </field>
        </record>

        <record id="rule_sub_consultant_all" model="ir.rule">
            <field name="name">العينات: الاستشاري يرى الكل</field>
            <field name="model_id" ref="model_contractor_material_submittal"/>
            <field name="groups" eval="[(4, ref('group_consultant_all'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- ══════════════════════════════════════════════════
             RECORD RULES — التأهيلات
        ══════════════════════════════════════════════════ -->
        <record id="rule_qual_contractor_own" model="ir.rule">
            <field name="name">التأهيلات: المستشار يرى تأهيلاته فقط</field>
            <field name="model_id" ref="model_contractor_qualification"/>
            <field name="groups" eval="[(4, ref('group_site_consultant'))]"/>
            <field name="domain_force">
                [('work_category_id', '=', user.waqf_portal_user_id.work_category_id.id),('state','!=','draft')]
            </field>
        </record>

        <record id="rule_qual_consultant_all" model="ir.rule">
            <field name="name">التأهيلات: الاستشاري يرى الكل</field>
            <field name="model_id" ref="model_contractor_qualification"/>
            <field name="groups" eval="[(4, ref('group_consultant_all'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
        <record id="rule_qual_group_waqf_admin" model="ir.rule">
            <field name="name">الوقف</field>
            <field name="model_id" ref="model_contractor_qualification"/>
            <field name="groups" eval="[(4, ref('group_waqf_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

    </data>
</odoo>
