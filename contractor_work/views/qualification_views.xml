<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_qualification_form" model="ir.ui.view">
        <field name="name">contractor.qualification.form</field>
        <field name="model">contractor.qualification</field>
        <field name="arch" type="xml">
            <form string="تأهيل المقاول">

                <header>

                    <!-- اعتماد المهندس -->
                    <button name="action_engineer_approve"
                            type="object"
                            string="اعتماد المهندس"
                            class="btn-success"
                            invisible="state != 'submitted'"/>

                    <!-- رفض المهندس -->
                    <button name="action_reject"
                            type="object"
                            string="رفض"
                            class="btn-danger"
                            invisible="state != 'submitted'"/>


                    <!-- اعتماد كبير المهندسين -->
                    <button name="action_senior_approve"
                            type="object"
                            string="اعتماد كبير المستشارين"
                            class="btn-success"
                            groups="contractor_work.group_consultant_all"
                            invisible="state in ['draft','submitted','senior_done','approved','rejected']"/>

                    <!-- رفض كبير المهندسين -->
                    <button name="action_reject"
                            type="object"
                            string="رفض"
                            class="btn-danger"
                            groups="contractor_work.group_consultant_all"
                            invisible="state in ['draft','submitted','senior_done','approved','rejected']"/>


                    <!-- اعتماد الوقف -->
                    <button name="action_waqf_approve"
                            type="object"
                            string="اعتماد الوقف"
                            class="btn-success"
                            groups="contractor_work.group_waqf_admin"
                             invisible="state in ['draft','submitted','engineer_done','approved','rejected']"/>

                    <!-- رفض الوقف -->
                    <button name="action_reject"
                            type="object"
                            string="رفض"
                            class="btn-danger"
                            groups="contractor_work.group_waqf_admin"
                             invisible="state in ['draft','submitted','engineer_done','approved','rejected']"/>


                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,engineer_done,senior_done,approved"/>

                </header>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>

                        <group>
                            <field name="supervisor_id" readonly="1"/>
                            <field name="work_category_id" readonly="1"/>

                            <field name="scope" widget="radio" readonly="1"/>

                            <field name="mosque_ids"
                                   readonly="1"
                                   widget="many2many_tags"
                                   invisible="scope != 'specific'"
                                   required="scope == 'specific'"/>

                            <field name="date_requested" readonly="1"/>
                        </group>

                        <group>
                            <field name="final_grade" readonly="1"/>

                            <field name="reject_reason"
                                   invisible="state != 'rejected'"/>

                            <field name="notes"/>
                        </group>

                    </group>

                    <group>
                        <field name="description" readonly="1"/>
                    </group>

                    <separator string="الوثائق والشهادات"/>

                    <field name="document_ids"
                           readonly="1"
                           widget="many2many_binary"/>

                    <notebook>

                        <!-- المهندس -->
                        <page string="تقييم المهندس">

                            <group>

                                <group>
                                    <field name="engineer_grade"/>
                                    <field name="engineer_notes"/>
                                </group>

                                <group>
                                    <field name="engineer_by" readonly="1"/>
                                    <field name="engineer_date" readonly="1"/>
                                </group>

                            </group>

                        </page>

                        <!-- كبير المهندسين -->
                        <page string="تقييم كبير المهندسين">

                            <group>

                                <group>
                                    <field name="senior_grade"/>
                                    <field name="senior_notes"/>
                                </group>

                                <group>
                                    <field name="senior_by" readonly="1"/>
                                    <field name="senior_date" readonly="1"/>
                                </group>

                            </group>

                        </page>

                        <!-- الوقف -->
                        <page string="اعتماد الوقف">

                            <group>

                                <group>
                                    <field name="waqf_grade"/>
                                    <field name="waqf_notes"/>
                                </group>

                                <group>
                                    <field name="waqf_by" readonly="1"/>
                                    <field name="waqf_date" readonly="1"/>
                                </group>

                            </group>

                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_qualification_list" model="ir.ui.view">
        <field name="name">contractor.qualification.list</field>
        <field name="model">contractor.qualification</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="supervisor_id"/>
                <field name="work_category_id"/>
                <field name="scope"/>
                <field name="date_requested"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_contractor_qualification" model="ir.actions.act_window">
        <field name="name">تأهيل المقاولين</field>
        <field name="res_model">contractor.qualification</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
