<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ══════════════════════════════════════════════════════
     BASE LAYOUT
══════════════════════════════════════════════════════ -->
<template id="tmpl_base" name="Contractor Portal Base">
  <t t-call="web.layout">
    <t t-set="head">
      <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
      <link rel="stylesheet" href="/waqf_contractor_portal/static/src/css/portal.css"/>
      <title>بوابة المقاول </title>
    </t>
    <body class="contractor-portal">

      <!-- Header -->
      <header class="cp-header">
        <div class="cp-header-brand">
          <div class="cp-header-logo">و</div>
          <div>
            <div class="cp-header-title">بوابة المقاول الميداني</div>
            <div class="cp-header-sub">وقف الملك عبدالله — مشاريع تأهيل المساجد</div>
          </div>
        </div>
        <div class="cp-header-user">
          <t t-if="portal_user">
            <span style="font-size:12px;color:rgba(255,255,255,0.6)">
              <t t-esc="portal_user.name"/>
            </span>
            <div class="cp-avatar">
              <t t-esc="(portal_user.name or 'م')[0]"/>
            </div>
          </t>
          <t t-elif="supervisor">
            <span style="font-size:12px;color:rgba(255,255,255,0.6)">
              <t t-esc="supervisor.name"/>
            </span>
            <div class="cp-avatar">
              <t t-esc="(supervisor.name or 'م')[0]"/>
            </div>
          </t>
          <a href="/web/session/logout"
             style="color:rgba(255,255,255,0.4);font-size:11px;margin-right:6px;
                    text-decoration:none;white-space:nowrap">
            خروج
          </a>
        </div>
      </header>

      <!-- Bottom Nav (Mobile) -->
      <nav class="cp-bottom-nav" id="cp-bottom-nav">
        <a href="/contractor" class="cp-bottom-nav-item active" id="nav-home">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 9l7-6 7 6v9H13v-5H7v5H3V9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
          <span>الرئيسية</span>
        </a>
        <a href="/contractor/logs" class="cp-bottom-nav-item" id="nav-logs">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="3" y="2" width="14" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7 7h6M7 11h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>الأعمال</span>
        </a>
        <a href="/contractor/work-orders" class="cp-bottom-nav-item" id="nav-orders">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 3v14M3 10h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>أوامر</span>
        </a>
        <a href="/contractor/certificate/new" class="cp-bottom-nav-item" id="nav-cert">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M6 9h8M6 13h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>مستخلص</span>
        </a>
      </nav>

      <div class="cp-container">
        <t t-out="0"/>
      </div>

      <script src="/waqf_contractor_portal/static/src/js/portal.js"/>
    </body>
  </t>
</template>

<!-- ══════════════════════════════════════════════════════
     NO MOSQUE
══════════════════════════════════════════════════════ -->
<template id="tmpl_no_mosque" name="No Mosque">
  <t t-call="waqf_contractor_portal.tmpl_base">
    <div style="text-align:center;padding:80px 20px">
      <div style="font-size:48px;margin-bottom:16px">🕌</div>
      <div style="font-size:16px;font-weight:600;color:var(--navy);margin-bottom:8px">
        لم يتم تعيين مسجد لك بعد
      </div>
      <div style="font-size:13px;color:var(--text3);line-height:1.6">
        تواصل مع مسؤول المشروع لتعيين المسجد المكلف به.
      </div>
    </div>
  </t>
</template>

<!-- ══════════════════════════════════════════════════════
     MOSQUE SELECT
══════════════════════════════════════════════════════ -->
<template id="tmpl_mosque_select" name="Contractor Mosque Select">
  <t t-call="waqf_contractor_portal.tmpl_base">

    <!-- User Hero -->
    <div class="cp-hero" style="margin-bottom:20px">
      <div class="cp-hero-identity">
        <div class="cp-hero-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="9" r="5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M4 24c0-5.5 4.5-10 10-10s10 4.5 10 10" stroke="currentColor"
                  stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="cp-hero-name">مرحباً، <t t-esc="portal_user.name"/></div>
          <div class="cp-hero-location">
            <t t-esc="portal_user.company_id.name or ''"/>
            <t t-if="portal_user.role">
              —
              <t t-if="portal_user.role == 'contractor_admin'">مشرف عام</t>
              <t t-elif="portal_user.role == 'site_supervisor'">مشرف موقع</t>
              <t t-else="">مهندس مقاول</t>
            </t>
          </div>
        </div>
      </div>
      <span class="cp-status-badge active">
        <span class="cp-status-dot"/>
        <t t-esc="len(mosques)"/> مسجد
      </span>
    </div>

    <!-- Mosque Grid -->
    <div style="font-size:11px;font-weight:600;color:var(--text3);
                letter-spacing:.5px;margin-bottom:12px">
      اختر الموقع للمتابعة
    </div>

    <div class="cp-mosque-grid">
      <t t-foreach="mosques" t-as="mosque">
        <a t-attf-href="/contractor/mosque/#{mosque.id}" class="cp-mosque-card-link">
          <div class="cp-mosque-select-card">
            <div class="cp-mosque-select-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 3C9.8 3 8 4.8 8 7v1H5l-2 2v10h18V10l-2-2h-3V7c0-2.2-1.8-4-4-4z"
                      stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
              </svg>
            </div>
            <div style="flex:1;min-width:0">
              <div style="font-size:13px;font-weight:700;color:var(--navy);
                          margin-bottom:3px;white-space:nowrap;overflow:hidden;
                          text-overflow:ellipsis">
                <t t-esc="mosque.name"/>
              </div>
              <div style="font-size:11px;color:var(--text3);display:flex;
                          align-items:center;gap:6px">
                <span style="font-family:monospace;color:var(--primary);font-weight:600">
                  <t t-esc="mosque.code"/>
                </span>
                <t t-if="mosque.city">
                  <span style="color:var(--border2)">·</span>
                  <t t-esc="mosque.city"/>
                </t>
              </div>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px">
              <span t-attf-class="cp-status-badge #{mosque.state == 'active' and 'active' or 'draft'}">
                <span class="cp-status-dot"/>
                <t t-if="mosque.state == 'active'">قيد التنفيذ</t>
                <t t-else="">لم يبدأ</t>
              </span>
              <span style="font-size:11px;color:var(--text3)">
                <t t-esc="'%.0f' % (mosque.overall_kpi or 0)"/>% KPI
              </span>
            </div>
          </div>
        </a>
      </t>
    </div>

  </t>
</template>

<!-- ══════════════════════════════════════════════════════
     HOME DASHBOARD
══════════════════════════════════════════════════════ -->
<template id="tmpl_home" name="Contractor Home">
  <t t-call="waqf_contractor_portal.tmpl_base">

    <!-- ── Toast Messages ───────────────────────── -->
    <t t-if="request.params.get('submitted') or request.params.get('cert_submitted') or request.params.get('co_submitted')">
      <div class="cp-toast-success">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.5"/>
          <path d="M5.5 9l2.5 2.5 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <t t-if="request.params.get('submitted')">تم إرسال العمل بنجاح</t>
        <t t-elif="request.params.get('cert_submitted')">تم إرسال المستخلص للاستشاري</t>
        <t t-elif="request.params.get('co_submitted')">تم إرسال طلب التعديل</t>
      </div>
    </t>

    <!-- ── Rejected Banner ───────────────────────── -->
    <t t-if="rejected_work_orders or rejected_logs">
      <div class="cp-alert-banner">
        <div class="cp-alert-banner-hdr">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 1.5L14.5 13H1.5L8 1.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
            <path d="M8 6v4M8 11.5v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          يتطلب إجراءً منك
        </div>
        <div class="cp-alert-items">
          <t t-foreach="rejected_work_orders[:3]" t-as="wo">
            <div class="cp-alert-item">
              <div>
                <span class="cp-alert-name"><t t-esc="wo.name"/> — <t t-esc="wo.work_description[:40]"/></span>
                <span class="cp-alert-reason">تقييم D — إعادة تسليم مطلوب</span>
              </div>
              <a t-attf-href="/contractor/work-order/#{wo.id}" class="cp-btn-sm cp-btn-danger">
                عرض
              </a>
            </div>
          </t>
          <t t-foreach="rejected_logs[:2]" t-as="rl">
            <div class="cp-alert-item">
              <div>
                <span class="cp-alert-name"><t t-esc="rl.name"/></span>
                <span class="cp-alert-reason"><t t-esc="rl.reject_reason or 'بدون سبب محدد'"/></span>
              </div>
              <a t-attf-href="/contractor/work/#{rl.id}/rejected" class="cp-btn-sm cp-btn-danger">
                تعديل
              </a>
            </div>
          </t>
        </div>
      </div>
    </t>

    <!-- ── Mosque Hero ───────────────────────────── -->
    <div class="cp-hero">
      <div class="cp-hero-identity">
        <div class="cp-hero-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d="M14 4C11.8 4 10 5.8 10 8v1H7l-3 3v12h20V12l-3-3h-3V8c0-2.2-1.8-4-4-4z"
                  stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M14 4v2M10 12h8M11 17h2M15 17h2" stroke="currentColor"
                  stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="cp-hero-name"><t t-esc="mosque.name"/></div>
          <div class="cp-hero-location">
            <t t-esc="mosque.district or ''"/>
            <t t-if="mosque.district and mosque.city"> — </t>
            <t t-esc="mosque.city or ''"/>
          </div>
        </div>
      </div>
      <div class="cp-hero-badges">
        <span t-attf-class="cp-status-badge #{mosque.state == 'active' and 'active' or 'draft'}">
          <span class="cp-status-dot"/>
          <t t-if="mosque.state == 'active'">قيد التنفيذ</t>
          <t t-elif="mosque.state == 'mobilizing'">التجهيز</t>
          <t t-else="">لم يبدأ</t>
        </span>
        <t t-if="mosque.days_delay > 0">
          <span class="cp-delay-badge">
            تأخير <t t-esc="mosque.days_delay"/> يوم
          </span>
        </t>
        <!-- Back to mosques list if multi-mosque -->
        <t t-if="portal_user and portal_user.mosque_count > 1">
          <a href="/contractor" style="font-size:11px;color:var(--text3);text-decoration:none">
            ← تغيير الموقع
          </a>
        </t>
      </div>
    </div>

    <!-- ── KPI Cards ─────────────────────────────── -->
    <div class="cp-kpi-grid">
      <div class="cp-kpi-card">
        <div class="cp-kpi-header">
          <span class="cp-kpi-label">الإنجاز المالي</span>
          <span class="cp-kpi-pct financial">
            <t t-esc="'%.0f' % (mosque.financial_progress or 0)"/>%
          </span>
        </div>
        <div class="cp-kpi-bar-track">
          <div class="cp-kpi-bar-fill financial"
               t-attf-style="width:#{min(mosque.financial_progress or 0, 100)}%"/>
        </div>
        <div class="cp-kpi-sub">
          <span>المعتمد</span>
          <span class="cp-kpi-value">
            <t t-esc="'{:,.0f}'.format(mosque.certified_amount or 0)"/> ر
          </span>
        </div>
      </div>

      <div class="cp-kpi-card">
        <div class="cp-kpi-header">
          <span class="cp-kpi-label">الإنجاز الزمني</span>
          <span class="cp-kpi-pct time">
            <t t-esc="'%.0f' % (mosque.time_progress or 0)"/>%
          </span>
        </div>
        <div class="cp-kpi-bar-track">
          <div class="cp-kpi-bar-fill time"
               t-attf-style="width:#{min(mosque.time_progress or 0, 100)}%"/>
        </div>
        <div class="cp-kpi-sub">
          <span>منذ البداية</span>
          <t t-if="mosque.planned_end">
            <span class="cp-kpi-value">حتى <t t-esc="mosque.planned_end"/></span>
          </t>
        </div>
      </div>

      <div class="cp-kpi-card cp-kpi-card-overall">
        <div class="cp-kpi-header">
          <span class="cp-kpi-label">الأداء العام</span>
          <span t-attf-class="cp-kpi-pct overall #{(mosque.overall_kpi or 0) >= 70 and 'good' or (mosque.overall_kpi or 0) >= 50 and 'warn' or 'bad'}">
            <t t-esc="'%.0f' % (mosque.overall_kpi or 0)"/>%
          </span>
        </div>
        <div class="cp-kpi-bar-track">
          <div t-attf-class="cp-kpi-bar-fill overall #{(mosque.overall_kpi or 0) >= 70 and 'good' or (mosque.overall_kpi or 0) >= 50 and 'warn' or 'bad'}"
               t-attf-style="width:#{min(mosque.overall_kpi or 0, 100)}%"/>
        </div>
        <div class="cp-kpi-sub">
          <span>قيمة العقد</span>
          <span class="cp-kpi-value">
            <t t-esc="'{:,.0f}'.format(mosque.contract_value or 0)"/> ر
          </span>
        </div>
      </div>
    </div>

    <!-- ── Work Orders Summary ─────────────────── -->
    <div class="cp-wo-summary">
      <a t-attf-href="/contractor/work-orders?mosque=#{mosque.id}&amp;state=submitted"
         class="cp-wo-stat">
        <div class="cp-wo-stat-val pending">
          <t t-esc="pending_wo_count or 0"/>
        </div>
        <div class="cp-wo-stat-lbl">بانتظار الاعتماد</div>
      </a>
      <div class="cp-wo-divider"/>
      <a t-attf-href="/contractor/work-orders?mosque=#{mosque.id}&amp;state=approved"
         class="cp-wo-stat">
        <div class="cp-wo-stat-val active">
          <t t-esc="active_wo_count or 0"/>
        </div>
        <div class="cp-wo-stat-lbl">قيد التنفيذ</div>
      </a>
      <div class="cp-wo-divider"/>
      <a t-attf-href="/contractor/work-orders?mosque=#{mosque.id}&amp;state=delivered"
         class="cp-wo-stat">
        <div class="cp-wo-stat-val delivered">
          <t t-esc="delivered_wo_count or 0"/>
        </div>
        <div class="cp-wo-stat-lbl">بانتظار التقييم</div>
      </a>
      <div class="cp-wo-divider"/>
      <a t-attf-href="/contractor/work-orders?mosque=#{mosque.id}"
         class="cp-wo-stat">
        <div class="cp-wo-stat-val total">
          <t t-esc="total_wo_count or 0"/>
        </div>
        <div class="cp-wo-stat-lbl">إجمالي الأوامر</div>
      </a>
    </div>

    <!-- ── Quick Actions ─────────────────────────── -->
    <div class="cp-quick-actions">
      <a t-attf-href="/contractor/work-orders/new?mosque=#{mosque.id}"
         class="cp-action-btn cp-action-primary">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        أمر عمل جديد
      </a>
      <a href="/contractor/certificate/new" class="cp-action-btn cp-action-secondary">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <rect x="2" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
          <path d="M5 7h6M5 10h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
        مستخلص جديد
      </a>
      <a t-attf-href="/contractor/qualifications/new"
         class="cp-action-btn cp-action-ghost">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M8 2l1.5 3 3.5.5-2.5 2.5.5 3.5L8 10l-3 1.5.5-3.5L3 5.5l3.5-.5L8 2z"
                stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
        </svg>
        طلب تأهيل
      </a>
      <a t-attf-href="/contractor/submittals/new?mosque=#{mosque.id}"
         class="cp-action-btn cp-action-ghost">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.4"/>
          <path d="M8 5v6M5 8l3-3 3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
        رفع عينة
      </a>
    </div>

    <!-- ── Main Layout ───────────────────────────── -->
    <div class="cp-layout">

      <!-- العمود الرئيسي -->
      <div class="cp-main-col">

        <!-- أوامر العمل الأخيرة -->
        <div class="cp-section">
          <div class="cp-section-hdr">
            <div class="cp-section-title">أوامر العمل الأخيرة</div>
            <a t-attf-href="/contractor/work-orders?mosque=#{mosque.id}"
               class="cp-btn-ghost" style="font-size:11px;padding:4px 10px">
              الكل
            </a>
          </div>

          <t t-if="not recent_work_orders">
            <div class="cp-empty-state">
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none" class="cp-empty-icon">
                <rect x="6" y="4" width="24" height="28" rx="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M12 13h12M12 18h8M12 23h6" stroke="currentColor"
                      stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <div class="cp-empty-title">لا توجد أوامر عمل بعد</div>
              <div class="cp-empty-sub">ابدأ بإنشاء أمر عمل جديد</div>
            </div>
          </t>

          <div class="cp-wo-list" t-if="recent_work_orders">
            <t t-foreach="recent_work_orders" t-as="wo">
              <a t-attf-href="/contractor/work-order/#{wo.id}" class="cp-wo-card">
                <!-- State indicator -->
                <div t-attf-class="cp-wo-state-bar #{wo.state}"/>

                <div class="cp-wo-card-body">
                  <div class="cp-wo-card-top">
                    <div>
                      <div class="cp-wo-card-num">
                        <t t-esc="wo.name"/>
                      </div>
                      <div class="cp-wo-card-desc">
                        <t t-esc="(wo.work_description or '')[:60]"/>
                      </div>
                    </div>
                    <div style="text-align:left;flex-shrink:0">
                      <span t-attf-class="cp-wo-badge #{wo.state}">
                        <t t-if="wo.state == 'draft'">مسودة</t>
                        <t t-elif="wo.state == 'submitted'">بانتظار البدء</t>
                        <t t-elif="wo.state == 'approved'">قيد التنفيذ</t>
                        <t t-elif="wo.state == 'delivered'">مسلّم</t>
                        <t t-elif="wo.state == 'graded'">تقييم <t t-esc="(wo.grade or '').upper()"/></t>
                        <t t-elif="wo.state == 'rework'">إعادة عمل</t>
                        <t t-elif="wo.state == 'testing'">اختبار</t>
                        <t t-elif="wo.state == 'warranty'">ضمان</t>
                        <t t-elif="wo.state == 'closed'">مغلق</t>
                      </span>
                    </div>
                  </div>

                  <!-- BOQ lines summary -->
                  <div class="cp-wo-card-meta">
                    <span>
                      <t t-esc="wo.total_qty_lines"/> بند
                    </span>
                    <span style="color:var(--border2)">·</span>
                    <span style="color:var(--primary);font-weight:600">
                      <t t-esc="'{:,.0f}'.format(wo.total_value)"/> ر
                    </span>
                    <t t-if="wo.grade">
                      <span style="color:var(--border2)">·</span>
                      <span t-attf-style="color:#{wo.grade in ['a','b'] and 'var(--green)' or 'var(--red)'}">
                        تقييم <t t-esc="wo.grade.upper()"/>
                        (<t t-esc="'%.0f' % wo.payment_pct"/>%)
                      </span>
                    </t>
                    <t t-if="wo.rework_count > 0">
                      <span style="color:var(--border2)">·</span>
                      <span style="color:var(--orange)">
                        <t t-esc="wo.rework_count"/> إعادة
                      </span>
                    </t>
                  </div>

                  <!-- Phase indicators -->
                  <div class="cp-wo-phases">
                    <div t-attf-class="cp-phase #{wo.state not in ['draft'] and 'done' or 'current'}">
                      بدء
                    </div>
                    <div class="cp-phase-line"/>
                    <div t-attf-class="cp-phase #{wo.state in ['delivered','graded','rework','testing','warranty','closed'] and 'done' or wo.state == 'approved' and 'current' or 'pending'}">
                      تسليم
                    </div>
                    <div class="cp-phase-line"/>
                    <div t-attf-class="cp-phase #{wo.state in ['testing','warranty','closed'] and 'done' or wo.state == 'graded' and 'current' or 'pending'}">
                      اختبار
                    </div>
                    <div class="cp-phase-line"/>
                    <div t-attf-class="cp-phase #{wo.state in ['warranty','closed'] and 'done' or 'pending'}">
                      ضمان
                    </div>
                  </div>
                </div>
              </a>
            </t>
          </div>
        </div>

        <!-- المهام المجدولة -->
        <div class="cp-section">
          <div class="cp-section-hdr">
            <div class="cp-section-title">المهام المجدولة</div>
            <span class="cp-section-count"><t t-esc="len(tasks)"/> مهمة</span>
          </div>

          <t t-if="not tasks">
            <div class="cp-empty-state">
              <div class="cp-empty-title">لا توجد مهام نشطة</div>
              <div class="cp-empty-sub">ستظهر المهام حسب الجدول الزمني للمشروع</div>
            </div>
          </t>

          <div class="cp-task-list" t-if="tasks">
            <t t-foreach="tasks" t-as="task">
              <div class="cp-task-row">
                <div class="cp-task-indicator"/>
                <div class="cp-task-info">
                  <div class="cp-task-name"><t t-esc="task.name"/></div>
                  <div class="cp-task-meta">
                    <t t-if="task.date_deadline">
                      الموعد: <t t-esc="task.date_deadline"/>
                    </t>
                    <t t-else="">بدون موعد محدد</t>
                    <t t-if="task.work_order_ids">
                      <span style="color:var(--border2)">·</span>
                      <span style="color:var(--primary)">
                        <t t-esc="len(task.work_order_ids)"/> أمر عمل
                      </span>
                    </t>
                  </div>
                </div>
                <a t-attf-href="/contractor/task/#{task.id}" class="cp-btn-outline">
                  فتح
                </a>
              </div>
            </t>
          </div>
        </div>

      </div>

      <!-- الشريط الجانبي -->
      <div class="cp-sidebar">

        <!-- أرقام سريعة -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px">
          <div class="cp-mini-stat">
            <div class="cp-mini-stat-val" style="color:var(--gold)">
              <t t-esc="mosque.certificate_count or 0"/>
            </div>
            <div class="cp-mini-stat-lbl">مستخلص</div>
          </div>
          <div class="cp-mini-stat">
            <div class="cp-mini-stat-val" style="color:var(--primary)">
              <t t-esc="mosque.boq_count or 0"/>
            </div>
            <div class="cp-mini-stat-lbl">بند كميات</div>
          </div>
          <div class="cp-mini-stat">
            <div class="cp-mini-stat-val" style="color:var(--green)">
              <t t-esc="mosque.change_order_count or 0"/>
            </div>
            <div class="cp-mini-stat-lbl">أمر تغيير</div>
          </div>
          <div class="cp-mini-stat">
            <div class="cp-mini-stat-val" style="color:var(--orange)">
              <t t-esc="active_submittals or 0"/>
            </div>
            <div class="cp-mini-stat-lbl">عينة</div>
          </div>
        </div>

        <!-- آخر الأعمال القديمة -->
        <div class="cp-section-hdr" style="margin-bottom:8px">
          <div class="cp-section-title" style="font-size:12px">آخر الأعمال</div>
          <a href="/contractor/logs" class="cp-btn-ghost"
             style="font-size:10px;padding:3px 8px">الكل</a>
        </div>

        <t t-if="not recent_logs">
          <div class="cp-empty-sm">
            <div class="cp-empty-title">لا توجد أعمال</div>
          </div>
        </t>

        <div class="cp-log-list" t-if="recent_logs">
          <t t-foreach="recent_logs" t-as="log">
            <div class="cp-log-row cp-log-row-sm">
              <div t-attf-class="cp-log-dot #{log.state}"/>
              <div class="cp-log-info">
                <div class="cp-log-name"><t t-esc="log.name"/></div>
                <div class="cp-log-meta">
                  <span class="cp-log-code"><t t-esc="log.boq_id.item_code"/></span>
                  <span class="cp-log-sep">·</span>
                  <span><t t-esc="log.log_date"/></span>
                </div>
              </div>
              <span t-attf-class="cp-status-pill #{log.state == 'approved' and 'approved' or log.state == 'submitted' and 'pending' or log.state == 'rejected' and 'rejected' or 'draft'}">
                <t t-if="log.state == 'draft'">مسودة</t>
                <t t-elif="log.state == 'submitted'">معلق</t>
                <t t-elif="log.state == 'approved'">معتمد</t>
                <t t-elif="log.state == 'rejected'">مرفوض</t>
              </span>
            </div>
          </t>
        </div>

        <!-- إنشاء مستخلص -->
        <a href="/contractor/certificate/new"
           class="cp-btn-primary cp-btn-block" style="margin-top:12px">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
            <path d="M6.5 1.5v10M1.5 6.5h10" stroke="currentColor"
                  stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          إنشاء مستخلص
        </a>

      </div>
    </div>

  </t>
</template>

<!-- ══════════════════════════════════════════════════════
     TASK DETAIL (محدث)
══════════════════════════════════════════════════════ -->
<template id="tmpl_task_detail" name="Task Detail">
  <t t-call="waqf_contractor_portal.tmpl_base">

    <div class="cp-breadcrumb">
      <a t-attf-href="/contractor/mosque/#{mosque.id}">الرئيسية</a>
      <span>←</span>
      <span><t t-esc="task.name"/></span>
    </div>

    <!-- Task Header -->
    <div class="cp-hero" style="margin-bottom:16px">
      <div class="cp-hero-identity">
        <div class="cp-hero-icon" style="width:44px;height:44px">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <rect x="2" y="2" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/>
            <path d="M6 8h10M6 12h7M6 16h4" stroke="currentColor"
                  stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="cp-hero-name" style="font-size:15px"><t t-esc="task.name"/></div>
          <div class="cp-hero-location">
            <t t-if="task.date_deadline">الموعد: <t t-esc="task.date_deadline"/></t>
            <t t-else="">بدون موعد محدد</t>
          </div>
        </div>
      </div>
      <!-- Work orders count for this task -->
      <t t-if="task.work_order_ids">
        <a t-attf-href="/contractor/work-orders?task=#{task.id}"
           class="cp-btn-outline" style="white-space:nowrap">
          <t t-esc="len(task.work_order_ids)"/> أوامر عمل
        </a>
      </t>
    </div>

    <div t-if="request.params.get('submitted')" class="cp-toast-success">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
        <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      تم تسجيل العمل بنجاح
    </div>

    <!-- New Work Order Button -->
    <a t-attf-href="/contractor/work-orders/new?mosque=#{mosque.id}&amp;task=#{task.id}"
       class="cp-btn-primary" style="margin-bottom:20px;display:inline-flex">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M7 1.5v11M1.5 7h11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      إنشاء أمر عمل لهذه المهمة
    </a>

    <!-- Work Log Form (Legacy) -->
    <div style="margin-bottom:20px">
      <div class="cp-section-hdr" style="margin-bottom:12px">
        <div class="cp-section-title">تسجيل عمل مباشر</div>
      </div>

      <form action="/contractor/work/submit" method="post" enctype="multipart/form-data">
        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
        <input type="hidden" name="task_id" t-att-value="task.id"/>
        <input type="hidden" id="boq_id" name="boq_id" value=""/>

        <div class="cp-form-card">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
            <div class="cp-form-group" style="margin-bottom:0;grid-column:1/-1">
              <label class="cp-label"><span>*</span> وصف العمل</label>
              <input type="text" name="name" class="cp-input"
                     placeholder="مثال: تغيير باب خشبي — المدخل الخلفي" required="required"/>
            </div>
            <div class="cp-form-group" style="margin-bottom:0">
              <label class="cp-label">موقع العمل</label>
              <input type="text" name="location_detail" class="cp-input"
                     placeholder="الجناح الشمالي..."/>
            </div>
            <div class="cp-form-group" style="margin-bottom:0">
              <label class="cp-label"><span>*</span> التاريخ</label>
              <input type="date" name="log_date" class="cp-input" required="required"/>
            </div>
          </div>

          <div class="cp-form-group">
            <label class="cp-label"><span>*</span> البند من جدول الكميات</label>
            <div class="cp-boq-select" style="max-height:200px;overflow-y:auto;border-radius:8px">
              <t t-foreach="boq_items" t-as="boq">
                <div class="cp-boq-option"
                     t-att-data-id="boq.id"
                     t-att-data-uom="boq.uom"
                     t-att-data-price="boq.unit_price"
                     t-att-data-remaining="boq.remaining_qty">
                  <div>
                    <div class="cp-boq-code"><t t-esc="boq.item_code"/></div>
                    <div class="cp-boq-name">
                      <t t-esc="(boq.description or '')[:55]"/>
                    </div>
                  </div>
                  <div class="cp-boq-remaining">
                    متبقي: <t t-esc="'%.1f' % boq.remaining_qty"/>
                    <t t-esc="boq.uom or ''"/>
                  </div>
                </div>
              </t>
            </div>
          </div>

          <div class="cp-form-group" style="margin-bottom:16px">
            <label class="cp-label"><span>*</span> الكمية</label>
            <div class="cp-qty-wrap">
              <button type="button" class="cp-qty-btn" data-action="dec">−</button>
              <input type="number" name="qty_executed" class="cp-qty-input"
                     value="1" min="0.1" step="0.5"/>
              <span class="cp-qty-uom">—</span>
              <button type="button" class="cp-qty-btn" data-action="inc">+</button>
            </div>
            <div style="margin-top:6px;font-size:12px;color:var(--text3)">
              القيمة:
              <strong id="value-preview" style="color:var(--primary)">0 ريال</strong>
            </div>
          </div>

          <button type="submit" class="cp-btn-primary cp-btn-block">
            حفظ وإضافة صور الإنجاز
          </button>
        </div>
      </form>
    </div>

    <!-- Previous Logs -->
    <t t-if="logs">
      <div class="cp-section-hdr" style="margin-bottom:12px">
        <div class="cp-section-title">الأعمال المسجلة</div>
        <span class="cp-section-count"><t t-esc="len(logs)"/></span>
      </div>
      <div class="cp-log-list">
        <t t-foreach="logs" t-as="log">
          <div class="cp-log-row">
            <div t-attf-class="cp-log-dot #{log.state}"/>
            <div class="cp-log-info">
              <div class="cp-log-name"><t t-esc="log.name"/></div>
              <div class="cp-log-meta">
                <span class="cp-log-code"><t t-esc="log.boq_id.item_code"/></span>
                <span class="cp-log-sep">·</span>
                <span><t t-esc="'%.2f' % log.qty_executed"/> <t t-esc="log.uom or ''" /></span>
                <span class="cp-log-sep">·</span>
                <span><t t-esc="log.log_date"/></span>
              </div>
              <t t-if="log.reject_reason">
                <div style="font-size:11px;color:var(--red);margin-top:3px">
                  ❌ <t t-esc="log.reject_reason"/>
                </div>
              </t>
            </div>
            <span t-attf-class="cp-status-pill #{log.state == 'approved' and 'approved' or log.state == 'submitted' and 'pending' or log.state == 'rejected' and 'rejected' or 'draft'}">
              <t t-if="log.state == 'draft'">مسودة</t>
              <t t-elif="log.state == 'submitted'">معلق</t>
              <t t-elif="log.state == 'approved'">معتمد</t>
              <t t-elif="log.state == 'rejected'">مرفوض</t>
            </span>
          </div>
        </t>
      </div>
    </t>

  </t>
</template>

</odoo>
