<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ══ TASK FORM — inherit & add review buttons + color ══════ -->
<record id="view_task_form_review_inherit" model="ir.ui.view">
    <field name="name">project.task.form.waqf.review</field>
    <field name="model">project.task</field>
    <field name="inherit_id" ref="project.view_task_form2"/>
    <field name="arch" type="xml">

        <!-- Status bar buttons — consultant actions -->
        <xpath expr="//header" position="inside">

            <!-- Consultant buttons -->
            <button name="action_consultant_approve"
                    string="✓ اعتماد الاستشاري"
                    type="object"
                    class="btn-success"
                    invisible="
                        stage_id.waqf_stage != 'consultant_review'
                        or review_state == 'approved'
                        or is_blocked_by_co"
                    groups="waqf_mosque_rehab.group_mosque_consultant"/>

            <button name="action_consultant_reject"
                    string="✗ رفض"
                    type="object"
                    class="btn-danger"
                    invisible="
                        stage_id.waqf_stage != 'consultant_review'
                        or review_state == 'rejected'"
                    groups="waqf_mosque_rehab.group_mosque_consultant"/>

            <!-- Waqf buttons -->
            <button name="action_waqf_approve"
                    string="✓ اعتماد الوقف"
                    type="object"
                    class="btn-success"
                    invisible="
                        stage_id.waqf_stage != 'waqf_approval'
                        or kanban_color != 'green'"
                    groups="waqf_mosque_rehab.group_mosque_waqf_manager"/>

            <button name="action_waqf_reject"
                    string="✗ إعادة للاستشاري"
                    type="object"
                    class="btn-warning"
                    invisible="stage_id.waqf_stage != 'waqf_approval'"
                    groups="waqf_mosque_rehab.group_mosque_waqf_manager"/>

        </xpath>

        <!-- Color indicator banner below header -->
        <xpath expr="//sheet" position="before">
            <!-- Green -->
            <div invisible="kanban_color != 'green'"
                 style="background:#D1F0E3;border-bottom:3px solid #2ECC8A;
                        padding:8px 16px;font-size:13px;font-weight:500;
                        color:#0D6B41;display:flex;align-items:center;gap:8px">
                ✅ معتمدة من الاستشاري
                <span style="font-weight:400;font-size:12px">
                    — <field name="approved_by" readonly="1" nolabel="1"/>
                    بتاريخ <field name="approved_date" readonly="1" nolabel="1"/>
                </span>
            </div>

            <!-- Red -->
            <div invisible="kanban_color != 'red'"
                 style="background:#FEE;border-bottom:3px solid #E85555;
                        padding:8px 16px;font-size:13px;font-weight:500;
                        color:#9B1C1C;display:flex;align-items:center;gap:8px">
                ❌ مرفوضة
                <span style="font-weight:400;font-size:12px">
                    — <field name="rejection_note" readonly="1" nolabel="1"/>
                </span>
            </div>

            <!-- Yellow -->
            <div invisible="kanban_color != 'yellow'"
                 style="background:#FFF8EC;border-bottom:3px solid #C8A454;
                        padding:8px 16px;font-size:13px;font-weight:500;
                        color:#856404;display:flex;align-items:center;gap:8px">
                🔒 مجمّدة — بانتظار اعتماد أمر التغيير:
                <field name="blocking_co_id" readonly="1" nolabel="1"/>
            </div>

            <!-- Orange -->
            <div invisible="kanban_color != 'orange'"
                 style="background:#FFF3E0;border-bottom:3px solid #F0A500;
                        padding:8px 16px;font-size:13px;font-weight:500;
                        color:#7A4F00;display:flex;align-items:center;gap:8px">
                ⏰ متأخرة — تجاوزت الموعد المحدد
            </div>
        </xpath>

        <!-- Subtask summary — main tasks only -->
        <xpath expr="//notebook" position="before">

            <!-- All subtasks green — ready for Waqf -->
            <div invisible="not subtasks_all_green or parent_id or not child_ids"
                 style="background:#D1F0E3;border:1px solid #2ECC8A;
                        border-radius:8px;padding:10px 16px;margin-bottom:8px;
                        font-size:13px;font-weight:500;color:#0D6B41;
                        display:flex;align-items:center;gap:8px">
                ✅ جميع المهام الفرعية معتمدة —
                المهمة جاهزة للانتقال لاعتماد الوقف
                (<field name="approved_subtask_count" readonly="1" nolabel="1"/>
                من
                <field name="child_ids" readonly="1" nolabel="1"
                       widget="integer_with_suffix"/>)
            </div>

            <!-- Not all green — show blocking list -->
            <div invisible="subtasks_all_green or parent_id or not child_ids"
                 style="background:#FFF8EC;border:1.5px solid #C8A454;
                        border-radius:8px;padding:12px 16px;margin-bottom:8px">
                <div style="font-size:13px;font-weight:600;
                            color:#856404;margin-bottom:6px">
                    ⚠ المهام الفرعية التالية لم تُعتمد بعد
                </div>
                <field name="subtasks_blocking_html"
                       readonly="1" nolabel="1"/>
                <div style="font-size:11px;color:#7A4F00;margin-top:6px">
                    اعتمد جميع المهام الفرعية أعلاه ← ستنتقل المهمة تلقائياً
                    لمرحلة اعتماد الوقف
                </div>
            </div>

            <!-- Subtask counters row -->
            <group string="المهام الفرعية"
                   invisible="not child_ids or parent_id">
                <group>
                    <field name="approved_subtask_count"
                           string="✅ معتمدة" readonly="1"/>
                    <field name="pending_subtask_count"
                           string="⏳ بانتظار الاعتماد" readonly="1"/>
                </group>
                <group>
                    <field name="rejected_subtask_count"
                           string="❌ مرفوضة" readonly="1"/>
                    <field name="subtasks_all_green"
                           string="جاهزة للوقف"
                           widget="boolean_toggle" readonly="1"/>
                </group>
            </group>

        </xpath>

    </field>
</record>

<!-- ══ KANBAN VIEW — color-coded cards ══════════════════════ -->
<record id="view_task_kanban_review_inherit" model="ir.ui.view">
    <field name="name">project.task.kanban.waqf.review</field>
    <field name="model">project.task</field>
   <field name="inherit_id" ref="project.view_task_kanban"/>
    <field name="arch" type="xml">

        <xpath expr="//kanban" position="attributes">
            <attribute name="class">waqf_kanban</attribute>
        </xpath>

        <!-- Override card color via kanban_color field -->
        <xpath expr="//t[@t-name='card']" position="replace">
            <t t-name="card"
               t-att-class="
                   'waqf-task-card ' +
                   (record.kanban_color.value == 'green'  ? 'waqf-green'  :
                    record.kanban_color.value == 'red'    ? 'waqf-red'    :
                    record.kanban_color.value == 'yellow' ? 'waqf-yellow' :
                    record.kanban_color.value == 'orange' ? 'waqf-orange' :
                    'waqf-grey')">

                <!-- Color strip at top -->
                <div class="waqf-card-strip"/>

                <!-- Task name -->
                <div class="waqf-card-name">
                    <field name="name"/>
                </div>

                <!-- Mosque code if available -->
                <div class="waqf-card-meta" t-if="record.mosque_code.value">
                    <field name="mosque_code"/>
                </div>

                <!-- Deadline -->
                <div class="waqf-card-deadline" t-if="record.date_deadline.value">
                    <field name="date_deadline"/>
                </div>

                <!-- CO lock indicator -->
                <div t-if="record.is_blocked_by_co.value"
                     class="waqf-card-co-lock">
                    🔒 مجمّد — CO معلق
                </div>

                <!-- Subtask progress bar — main tasks only -->
                <div class="waqf-card-subtasks"
                     t-if="!record.parent_id.value &amp;&amp; record.child_ids.raw_value">
                    <div class="waqf-subtask-progress">
                        <div class="waqf-subtask-bar">
                            <div class="waqf-subtask-fill"
                                 t-attf-style="width:#{
                                     record.approved_subtask_count.value /
                                     (record.approved_subtask_count.value +
                                      record.pending_subtask_count.value +
                                      record.rejected_subtask_count.value + 0.001)
                                     * 100}%"/>
                        </div>
                        <span class="waqf-subtask-label">
                            <field name="approved_subtask_count"/>/<t
                                t-esc="(record.approved_subtask_count.value or 0) +
                                       (record.pending_subtask_count.value or 0) +
                                       (record.rejected_subtask_count.value or 0)"/>
                            معتمدة
                        </span>
                    </div>
                    <span t-if="record.rejected_subtask_count.value > 0"
                          class="waqf-count waqf-count-rejected">
                        ✗ <field name="rejected_subtask_count"/>
                    </span>
                    <span t-if="record.is_blocked_by_co.value"
                          class="waqf-count"
                          style="background:#FFF3CD;color:#856404">
                        🔒
                    </span>
                </div>

                <footer>
                    <field name="user_ids" widget="many2many_avatar_user"/>
                    <!-- Quick approve button for consultant -->
                    <button t-if="record.stage_id.raw_value &amp;&amp;
                                  record.review_state.value == 'submitted'"
                            name="action_consultant_approve"
                            type="object"
                            class="btn btn-sm btn-success ms-auto"
                            title="اعتماد سريع">✓</button>
                </footer>
            </t>
        </xpath>

    </field>
</record>


<!-- ══ TASK LIST — add review state column ══════════════════ -->
<record id="view_task_list_review_inherit" model="ir.ui.view">
    <field name="name">project.task.list.waqf.review</field>
    <field name="model">project.task</field>
    <field name="inherit_id" ref="project.view_task_tree2"/>
    <field name="arch" type="xml">
        <xpath expr="//list" position="inside">
            <field name="kanban_color"
                   optional="show"
                   string="الحالة"
                   widget="badge"
                   decoration-success="kanban_color == 'green'"
                   decoration-danger="kanban_color == 'red'"
                   decoration-warning="kanban_color == 'yellow' or kanban_color == 'orange'"
                   decoration-muted="kanban_color == 'grey'"/>
            <field name="pending_subtask_count"
                   optional="show" string="بانتظار اعتماد"/>
            <field name="is_blocked_by_co"
                   optional="show" string="مجمّد"
                   widget="boolean_toggle"/>
        </xpath>
    </field>
</record>

<!-- ══ SEARCH — add review state filters ════════════════════ -->
<record id="view_task_search_review_inherit" model="ir.ui.view">
    <field name="name">project.task.search.waqf.review</field>
    <field name="model">project.task</field>
    <field name="inherit_id" ref="project.view_task_search_form"/>
    <field name="arch" type="xml">
        <xpath expr="//search/filter[last()]" position="after">
            <separator/>
            <filter string="بانتظار اعتمادي (استشاري)"
                    name="pending_consultant"
                    domain="[('review_state','=','submitted'),
                              ('stage_id.waqf_stage','=','consultant_review')]"/>
            <filter string="مرفوضة"
                    name="rejected_tasks"
                    domain="[('review_state','=','rejected')]"/>
            <filter string="مجمّدة — CO معلق"
                    name="blocked_co"
                    domain="[('is_blocked_by_co','=',True)]"/>
            <filter string="خضراء — معتمدة"
                    name="green_tasks"
                    domain="[('kanban_color','=','green')]"/>
            <filter string="بانتظار الوقف"
                    name="pending_waqf"
                    domain="[('stage_id.waqf_stage','=','waqf_approval')]"/>
        </xpath>
    </field>
</record>

</odoo>
