<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Five Waqf workflow stages — created once at install.
        Assigned to mosque projects via waqf_mosque_project module.
    -->

    <record id="stage_todo" model="project.task.type">
        <field name="name">To Do</field>
        <field name="sequence">1</field>
        <field name="waqf_stage">todo</field>
        <field name="require_green">False</field>
    </record>

    <record id="stage_in_progress" model="project.task.type">
        <field name="name">In Progress</field>
        <field name="sequence">2</field>
        <field name="waqf_stage">in_progress</field>
        <field name="require_green">False</field>
        <field name="is_closing_stage">False</field>
    </record>

    <record id="stage_consultant_review" model="project.task.type">
        <field name="name">Consultant Review</field>
        <field name="sequence">3</field>
        <field name="waqf_stage">consultant_review</field>
        <field name="require_green">False</field>
        <field name="is_closing_stage">False</field>
    </record>

    <record id="stage_waqf_approval" model="project.task.type">
        <field name="name">Waqf Approval</field>
        <field name="sequence">4</field>
        <field name="waqf_stage">waqf_approval</field>
        <field name="require_green">True</field>
        <field name="is_closing_stage">False</field>
    </record>

    <record id="stage_done" model="project.task.type">
        <field name="name">Done</field>
        <field name="sequence">5</field>
        <field name="waqf_stage">done</field>
        <field name="require_green">False</field>
        <field name="is_closing_stage">True</field>
        <field name="fold">True</field>
    </record>
</odoo>
