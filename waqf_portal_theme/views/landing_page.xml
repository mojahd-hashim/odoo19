<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="tmpl_landing" name="Waqf Landing Page">
<t t-call="web.layout">
<t t-set="head">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
  <link rel="stylesheet" href="/waqf_portal_theme/static/src/css/theme.css"/>
</t>
<body class="waqf-landing">
<div class="wl">

  <!-- ── Header ────────────────────────────────────────── -->
  <header class="wl-hdr">
    <div class="wl-brand">

      <!-- Logo: شعار الشركة أو fallback SVG -->
      <div class="wl-logo">
        <t t-if="company and company.logo">
          <img t-att-src="'/web/image/res.company/%d/logo' % company.id"
               t-att-alt="company.name"/>
        </t>
        <t t-else="">
          <!-- SVG mosque icon fallback -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C10 4 8 5 8 8h8c0-3-2-4-4-6z"/>
            <path d="M4 22V12a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10"/>
            <path d="M2 22h20"/>
            <path d="M7 22v-6h10v6"/>
            <circle cx="12" cy="7" r="1"/>
            <path d="M6 12v-2"/>
            <path d="M18 12v-2"/>
          </svg>
        </t>
      </div>

      <div>
        <div class="wl-company"
             t-esc="company.name if company else 'وقف خادم الحرمين الشريفين'"/>
        <div class="wl-tagline">نظام متابعة تأهيل المساجد</div>
      </div>
    </div>
  </header>

  <!-- ── Hero ──────────────────────────────────────────── -->
  <main class="wl-hero">

    <!-- Badge -->
    <div class="wl-badge">
      <!-- Star-crescent SVG -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/>
        <path d="M19.5 8.5l.5-.5-.5-.5-.5.5z"/>
      </svg>
      وقف خادم الحرمين الشريفين الملك عبدالله بن عبدالعزيز لوالديه – يرحمهم الله
    </div>

    <!-- Title -->
    <h1 class="wl-title">
      نظام متابعة تأهيل المساجد
      <em class="wl-title-sub">
        التي يرعاها الوقف
      </em>
    </h1>

    <p class="wl-desc">
      منصة متكاملة تربط الوقف بالمستشارين والمقاولين
      لمتابعة مشاريع الصيانة والتأهيل وضمان الجودة.
    </p>

    <!-- ── Entry Gates ────────────────────────────────── -->
    <div class="wl-gates">

      <!-- Gate 1: Waqf + Consultants -->
      <a class="wl-gate navy" href="/web/login">
        <div class="gate-ico">
          <!-- Building columns / institution icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 22V9L12 2l9 7v13"/>
            <path d="M9 22V12h6v10"/>
            <rect x="3" y="9" width="18" height="1" rx=".5"/>
          </svg>
        </div>
        <div class="gate-body">
          <div class="gate-title">بوابة موظفي الوقف والمستشارين</div>
          <div class="gate-desc">إدارة المشاريع والاعتمادات والتقارير التنفيذية</div>
          <div class="gate-tags">
            <span class="gate-tag">إدراة المشاريع بالوقف </span>
            <span class="gate-tag">الاستشاري</span>
          </div>
        </div>
        <div class="gate-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </div>
      </a>

      <!-- Gate 2: Field Supervisors -->
      <a class="wl-gate teal" href="/contractor">
        <div class="gate-ico">
          <!-- Hard hat / field work icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 18h20"/>
            <path d="M12 2v6"/>
            <path d="M4.93 6.93A8 8 0 0 1 20 12H4a8 8 0 0 1 .93-5.07z"/>
            <path d="M20 18v2"/>
            <path d="M4 18v2"/>
          </svg>
        </div>
        <div class="gate-body">
          <div class="gate-title">بوابة المشرفين الميدانيين</div>
          <div class="gate-desc">تسجيل الأعمال ورفع الصور وإرسال المستخلصات</div>
          <div class="gate-tags">
            <span class="gate-tag">مشرف الموقع</span>
            <span class="gate-tag">المقاول</span>
          </div>
        </div>
        <div class="gate-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </div>
      </a>

      <!-- Gate 3: Executive Dashboard -->
      <a class="wl-gate gold" href="/web/login?redirect=/dashboard">
        <div class="gate-featured">الإدارة العليا</div>
        <div class="gate-ico">
          <!-- Chart / analytics icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="20" x2="18" y2="10"/>
            <line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6"  y1="20" x2="6"  y2="14"/>
            <path d="M3 20h18"/>
          </svg>
        </div>
        <div class="gate-body">
          <div class="gate-title">لوحة الإدارة التنفيذية</div>
          <div class="gate-desc">مؤشرات الأداء والمخططات التفاعلية لجميع المشاريع</div>
          <div class="gate-tags">
          </div>
        </div>
        <div class="gate-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </div>
      </a>

    </div>
  </main>

  <!-- ── Footer ─────────────────────────────────────────── -->
  <footer class="wl-footer">
    © <t t-esc="company.name if company else 'وقف خادم الحرمين الشريفين'"/>
    — جميع الحقوق محفوظة 1446هـ
  </footer>

</div>
</body>
</t>
</template>
</odoo>