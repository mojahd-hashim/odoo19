<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="tmpl_landing" name="Waqf Landing Page">
<t t-call="web.layout">
<t t-set="head">
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin"/>
  <link href="https://fonts.googleapis.com/css2?family=Almarai:wght@300;400;700;800&amp;display=swap" rel="stylesheet"/>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{
      --primary:#006B84;--primary-light:#2B8BA3;--primary-dark:#08333D;
      --green:#2F7D5B;--green-light:#E8F3EE;
      --gold:#8A7A4F;--gold-light:#F2EBDD;
      --ivory:#F7F5EF;--white:#FFFFFF;
      --text:#17343B;--muted:#64747A;--border:#DDE4E6;
      --shadow-soft:0 10px 30px rgba(8,51,61,0.08);
      --shadow-strong:0 24px 70px rgba(8,51,61,0.18);
      --radius-xl:30px;
    }
    html{scroll-behavior:smooth}
    body{font-family:"Almarai",Arial,sans-serif;color:var(--text);background:var(--ivory);line-height:1.8;direction:rtl}
    a{color:inherit;text-decoration:none}
    img{display:block;width:100%;max-width:100%}
    .container{width:min(1180px,calc(100% - 36px));margin:0 auto}

    /* Header */
    .site-header{position:sticky;top:0;z-index:50;background:rgba(8,51,61,0.96);
      color:var(--white);border-bottom:1px solid rgba(255,255,255,0.12);
      backdrop-filter:blur(14px);box-shadow:0 8px 25px rgba(8,51,61,0.16)}
    .header-inner{min-height:76px;display:flex;align-items:center;
      justify-content:space-between;gap:24px}
    .brand{display:flex;align-items:center;gap:12px;min-width:0}
    .brand-mark{width:48px;height:48px;border-radius:16px;overflow:hidden;
      flex-shrink:0;display:grid;place-items:center;
      background:linear-gradient(135deg,var(--primary),var(--green));
      box-shadow:0 12px 30px rgba(0,107,132,0.28)}
    .brand-mark img{width:100%;height:100%;object-fit:contain}
    .brand-mark-fb{font-size:25px;color:var(--white)}
    .brand-title{font-size:15px;font-weight:800;line-height:1.4}
    .brand-subtitle{color:rgba(255,255,255,0.66);font-size:11px;margin-top:2px}
    .main-nav{display:flex;align-items:center;justify-content:center;gap:26px;flex:1}
    .main-nav a{font-size:14px;font-weight:700;color:rgba(255,255,255,0.86);
      transition:0.2s;white-space:nowrap}
    .main-nav a:hover{color:var(--white)}
    .header-login-btn{display:inline-flex;align-items:center;justify-content:center;
      min-height:44px;padding:10px 18px;border-radius:999px;
      background:var(--gold);color:var(--white);border:1px solid var(--gold);
      font-size:13px;font-weight:800;white-space:nowrap;transition:0.22s}
    .header-login-btn:hover{transform:translateY(-2px);
      box-shadow:0 12px 25px rgba(138,122,79,0.34)}

    /* Badges */
    .badge{display:inline-flex;align-items:center;gap:8px;padding:7px 14px;
      border-radius:999px;font-weight:800;font-size:13px;
      border:1px solid transparent;white-space:nowrap}
    .badge.blue{background:#E5F3F6;color:var(--primary);border-color:#B9DDE5}
    .badge.green{background:var(--green-light);color:var(--green);border-color:#B9DAC8}
    .badge.gold{background:var(--gold-light);color:var(--gold);border-color:#D8C99C}
    .badge.light{background:rgba(255,255,255,0.13);color:var(--white);
      border-color:rgba(255,255,255,0.22)}

    .section-title{text-align:center;max-width:830px;margin:0 auto 48px}
    .section-title .eyebrow{color:var(--gold);font-size:15px;font-weight:800;margin-bottom:10px}
    .section-title h2{color:var(--primary-dark);font-size:clamp(30px,4.4vw,46px);
      line-height:1.3;font-weight:800;letter-spacing:-0.6px}
    .section-title p{margin-top:16px;color:var(--muted);font-size:18px}

    .card{background:rgba(255,255,255,0.95);border:1px solid var(--border);
      border-radius:var(--radius-xl);padding:26px;
      box-shadow:var(--shadow-soft);transition:0.28s}
    .card:hover{transform:translateY(-5px);box-shadow:var(--shadow-strong);
      border-color:rgba(0,107,132,0.25)}

    .icon-box{width:58px;height:58px;border-radius:19px;display:grid;
      place-items:center;background:#E5F3F6;color:var(--primary);
      font-size:28px;margin-bottom:18px}
    .icon-box.green{background:var(--green-light);color:var(--green)}
    .icon-box.gold{background:var(--gold-light);color:var(--gold)}

    .check-list{list-style:none;display:grid;gap:11px;margin-top:20px}
    .check-list li{display:grid;grid-template-columns:23px 1fr;
      gap:10px;color:#355057;font-size:14px;line-height:1.75}
    .check-list li::before{content:"✓";color:var(--green);font-weight:800}

    /* Hero */
    .hero{position:relative;overflow:hidden;min-height:720px;display:flex;
      align-items:center;color:var(--white);background:var(--primary-dark)}
    .hero::before{content:"";position:absolute;inset:0;
      background:linear-gradient(270deg,rgba(8,51,61,0.98),rgba(8,51,61,0.86),rgba(0,107,132,0.70)),
      url("https://images.unsplash.com/photo-1591588582259-e675bd2e6088?q=80&amp;w=1600&amp;auto=format&amp;fit=crop") center/cover}
    .hero::after{content:"";position:absolute;width:600px;height:600px;
      left:-160px;top:-150px;border-radius:50%;
      background:radial-gradient(circle,rgba(138,122,79,0.34),transparent 68%);
      animation:float 9s ease-in-out infinite}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(22px)}}
    .hero-grid{position:relative;z-index:1;display:grid;
      grid-template-columns:1.05fr 0.95fr;gap:44px;
      align-items:center;padding:90px 0}
    .hero h1{margin-top:22px;font-size:clamp(38px,6vw,66px);
      line-height:1.18;font-weight:800;letter-spacing:-1px}
    .hero-text{margin-top:24px;max-width:720px;
      color:rgba(255,255,255,0.82);font-size:19px}
    .hero-badges{display:flex;flex-wrap:wrap;gap:10px}
    .hero-actions{display:flex;flex-wrap:wrap;gap:13px;margin-top:32px}
    .hero-link{min-height:54px;display:inline-flex;align-items:center;
      justify-content:center;border-radius:18px;padding:14px 22px;
      font-weight:800;transition:0.24s}
    .hero-link.main{background:var(--gold);color:var(--white);
      box-shadow:0 14px 34px rgba(0,0,0,0.18)}
    .hero-link.outline{background:rgba(255,255,255,0.10);color:var(--white);
      border:1px solid rgba(255,255,255,0.24);backdrop-filter:blur(12px)}
    .hero-link:hover{transform:translateY(-3px)}

    /* Access Panel */
    .access-panel{border:1px solid rgba(255,255,255,0.18);
      background:rgba(255,255,255,0.11);backdrop-filter:blur(18px);
      padding:17px;border-radius:34px;box-shadow:0 28px 80px rgba(0,0,0,0.28)}
    .access-panel-inner{border-radius:25px;background:var(--white);
      color:var(--text);padding:22px}
    .access-panel-header{display:flex;align-items:center;
      justify-content:space-between;gap:16px;margin-bottom:18px}
    .access-panel-header small{display:block;color:var(--primary);
      font-weight:800;margin-bottom:4px}
    .access-panel-header h3{color:var(--primary-dark);font-size:24px;line-height:1.35}
    .secure-icon{width:50px;height:50px;border-radius:18px;display:grid;
      place-items:center;color:var(--green);background:var(--green-light);
      font-size:26px;flex:0 0 auto}
    .role-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .role-card{min-height:132px;border:1px solid var(--border);border-radius:20px;
      padding:16px;background:linear-gradient(180deg,#FFFFFF 0%,#FAFAF8 100%);
      transition:0.24s;display:block}
    .role-card:hover{transform:translateY(-4px);border-color:var(--primary);
      box-shadow:0 12px 28px rgba(0,107,132,0.12)}
    .role-card .role-icon{width:42px;height:42px;border-radius:15px;
      display:grid;place-items:center;background:#E5F3F6;
      color:var(--primary);font-size:23px;margin-bottom:10px}
    .role-card h4{color:var(--primary-dark);font-size:15px;
      line-height:1.45;font-weight:800}
    .role-card p{margin-top:7px;color:var(--muted);font-size:12px;line-height:1.55}
    .role-card.main-role{background:linear-gradient(135deg,#F2EBDD 0%,#FFFFFF 100%);
      border-color:#D8C99C}
    .role-card.main-role .role-icon{background:var(--gold);color:var(--white)}
    .panel-note{margin-top:16px;padding:13px 15px;border-radius:17px;
      background:#EEF7FA;color:#315963;font-size:12px;line-height:1.7;
      border:1px solid #C9E6EC}
    .panel-login-main{display:flex;align-items:center;justify-content:center;
      min-height:52px;margin-top:16px;border-radius:18px;
      background:var(--primary);color:var(--white);font-size:14px;
      font-weight:800;transition:0.22s}
    .panel-login-main:hover{transform:translateY(-2px);background:var(--primary-dark)}

    /* Quick */
    .quick-section{padding:54px 0 22px}
    .quick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    .quick-card h3{color:var(--primary-dark);font-size:20px;margin-bottom:8px}
    .quick-card p{color:var(--muted);font-size:14px}

    /* Stakeholders */
    .stakeholders-section{padding:78px 0;background:var(--ivory)}
    .stakeholder-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
    .stakeholder-card{position:relative;overflow:hidden}
    .stakeholder-card::before{content:"";position:absolute;width:130px;height:130px;
      right:-52px;top:-52px;border-radius:50%;
      background:radial-gradient(circle,rgba(0,107,132,0.12),transparent 70%)}
    .stakeholder-top{position:relative;z-index:1;display:flex;
      align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:18px}
    .stakeholder-card h3,.stakeholder-card p,.stakeholder-card ul{position:relative;z-index:1}
    .stakeholder-card h3{color:var(--primary-dark);font-size:21px;line-height:1.45;margin-bottom:9px}
    .stakeholder-card p{color:var(--muted);font-size:14px}

    /* Virtual */
    .virtual-section{padding:78px 0}
    .virtual-box{display:grid;grid-template-columns:1fr 1fr;
      align-items:center;gap:36px;border-radius:42px;padding:28px;
      color:var(--white);background:var(--primary-dark);
      box-shadow:var(--shadow-strong);overflow:hidden}
    .virtual-media{min-height:430px;border-radius:32px;overflow:hidden;
      position:relative;background:#0f4a5c}
    .virtual-media img{height:100%;min-height:430px;object-fit:cover}
    .virtual-media::after{content:"";position:absolute;inset:0;
      background:linear-gradient(0deg,rgba(0,0,0,0.72),rgba(0,0,0,0.05))}
    .live-overlay{position:absolute;z-index:2;inset-inline:22px;bottom:22px;
      border-radius:22px;padding:18px;color:var(--white);
      background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.24);
      backdrop-filter:blur(16px)}
    .live-title{display:flex;align-items:center;gap:10px;font-weight:800;margin-bottom:7px}
    .live-dot{width:13px;height:13px;border-radius:999px;background:#EF4444;
      box-shadow:0 0 0 9px rgba(239,68,68,0.25)}
    .live-overlay p{color:rgba(255,255,255,0.82);font-size:13px}
    .virtual-content h2{margin-top:20px;font-size:clamp(30px,4vw,48px);
      line-height:1.28;font-weight:800}
    .virtual-content p{margin-top:18px;color:rgba(255,255,255,0.78);font-size:17px}
    .virtual-points{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-top:25px}
    .virtual-point{border-radius:18px;padding:15px;
      background:rgba(255,255,255,0.10);color:rgba(255,255,255,0.90);font-size:14px}

    /* Dashboard */
    .dashboard-section{padding:78px 0;background:var(--white)}
    .dashboard-shell{background:linear-gradient(135deg,var(--ivory) 0%,#F0F0ED 100%);
      border:1px solid var(--border);border-radius:32px;padding:26px;
      box-shadow:var(--shadow-strong);overflow:hidden}
    .dashboard-header{display:flex;align-items:center;justify-content:space-between;
      gap:16px;padding-bottom:22px;margin-bottom:22px;border-bottom:1px solid var(--border)}
    .dashboard-header h3{color:var(--primary-dark);font-size:22px;font-weight:800}
    .dashboard-tabs{display:flex;gap:8px;min-width:270px}
    .dashboard-tab{height:10px;border-radius:999px;flex:1;background:#DDE4E6}
    .dashboard-tab.active{background:linear-gradient(90deg,var(--primary),var(--green))}
    .metrics-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
    .metric-box{border-radius:20px;background:var(--white);padding:22px;
      border-top:4px solid var(--primary);
      box-shadow:0 6px 18px rgba(8,51,61,0.06);text-align:center}
    .metric-value{color:var(--primary);font-size:32px;font-weight:800;line-height:1.1}
    .metric-label{margin-top:8px;color:var(--muted);font-size:13px}

    /* Workflow */
    .workflow-section{padding:78px 0;background:var(--ivory)}
    .steps{display:grid;grid-template-columns:repeat(5,1fr);gap:16px}
    .step{border:1px solid var(--border);border-radius:26px;padding:24px;
      background:var(--white);box-shadow:var(--shadow-soft)}
    .step-number{color:rgba(0,107,132,0.18);font-size:42px;line-height:1;font-weight:800}
    .step h3{margin-top:18px;color:var(--primary-dark);font-size:19px;font-weight:800}
    .step p{margin-top:10px;color:var(--muted);font-size:14px}

    /* Features */
    .features-section{padding:78px 0;background:linear-gradient(180deg,#FFFFFF 0%,#F7F5EF 100%)}
    .features-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    .feature-card{border-left:4px solid var(--primary)}
    .feature-card h3{color:var(--primary-dark);font-size:18px;margin-bottom:8px}
    .feature-card p{color:var(--muted);font-size:14px}

    /* Integrations */
    .integrations-section{padding:78px 0;background:var(--white)}
    .integration-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    .integration-card{text-align:center}
    .integration-icon{width:62px;height:62px;display:grid;place-items:center;
      margin:0 auto 16px;border-radius:22px;background:var(--gold-light);
      color:var(--gold);font-size:30px}
    .integration-card h3{color:var(--primary-dark);font-size:17px;margin-bottom:8px}
    .integration-card p{color:var(--muted);font-size:13px}

    /* Final */
    .final-section{padding:78px 0;background:var(--ivory)}
    .final-box{border-radius:42px;padding:52px 30px;text-align:center;color:var(--white);
      background:linear-gradient(270deg,var(--primary),var(--green));
      box-shadow:var(--shadow-strong)}
    .final-box h2{max-width:900px;margin:0 auto;font-size:clamp(30px,4.6vw,50px);
      line-height:1.3;font-weight:800}
    .final-box p{margin:18px auto 0;max-width:800px;
      color:rgba(255,255,255,0.82);font-size:18px}

    footer{background:var(--primary-dark);color:rgba(255,255,255,0.82);
      text-align:center;padding:28px 18px;font-size:13px}

    @media(max-width:1120px){
      .header-inner{flex-wrap:wrap;padding:12px 0}
      .main-nav{order:3;flex-basis:100%;justify-content:flex-start;
        overflow-x:auto;padding-bottom:4px}
      .hero-grid,.virtual-box{grid-template-columns:1fr}
      .quick-grid,.stakeholder-grid,.features-grid,
      .integration-grid,.metrics-grid{grid-template-columns:repeat(2,1fr)}
      .steps{grid-template-columns:repeat(3,1fr)}
    }
    @media(max-width:700px){
      .container{width:min(100% - 24px,1180px)}
      .site-header{position:relative}
      .main-nav{gap:18px}
      .header-login-btn{width:100%}
      .hero{min-height:auto}
      .hero-grid{padding:58px 0}
      .hero-text,.section-title p,.virtual-content p,
      .final-box p{font-size:16px}
      .role-grid,.quick-grid,.stakeholder-grid,.features-grid,
      .integration-grid,.metrics-grid,.steps,
      .virtual-points{grid-template-columns:1fr}
      .dashboard-header{align-items:flex-start;flex-direction:column}
      .dashboard-tabs{min-width:100%}
      .card,.step{padding:21px}
      .virtual-box,.final-box{border-radius:28px;padding:20px}
      .virtual-media,.virtual-media img{min-height:310px}
    }
  </style>
</t>
<body>

<!-- ══ Header ══════════════════════════════════════════════ -->
<header class="site-header">
  <div class="container header-inner">
    <a href="#top" class="brand">
      <div class="brand-mark">
        <t t-if="company and company.logo">
          <img t-att-src="'/web/image/res.company/%d/logo' % company.id"
               t-att-alt="company.name"/>
        </t>
        <t t-else=""><span class="brand-mark-fb">🕌</span></t>
      </div>
      <div>
        <div class="brand-title">
          <t t-esc="company.name if company else 'بوابة تأهيل المساجد'"/>
        </div>
        <div class="brand-subtitle">نظام متابعة مشاريع الصيانة والتأهيل</div>
      </div>
    </a>

    <nav class="main-nav">
      <a href="#stakeholders">المستفيدون</a>
      <a href="#virtual">الزيارة الافتراضية</a>
      <a href="#dashboard">لوحة المتابعة</a>
      <a href="#features">المميزات</a>
    </nav>

    <a class="header-login-btn" href="/web/login">تسجيل الدخول</a>
  </div>
</header>

<!-- ══ Main ════════════════════════════════════════════════ -->
<main id="top">

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <div class="hero-badges">
          <span class="badge gold">بوابة تقنية لإدارة التأهيل</span>
          <span class="badge green">حوكمة المشاريع الميدانية</span>
        </div>
        <h1>منصة موحدة لإدارة مشاريع تأهيل المساجد من الموقع إلى الاعتماد</h1>
        <p class="hero-text">
          حل رقمي متكامل يربط مسؤولي الوقف، ومديري المشاريع، والمستشارين المقيمين،
          والمقاولين؛ لتسريع المتابعة، ضبط الاعتمادات، توثيق الشواهد،
          وتمكين الزيارة الافتراضية الحية لمواقع المشاريع.
        </p>
        <div class="hero-actions">
          <a class="hero-link main" href="#access">الدخول للمنصة</a>
          <a class="hero-link outline" href="#virtual">الزيارة الافتراضية</a>
        </div>
      </div>

      <!-- Access Panel -->
      <aside class="access-panel" id="access">
        <div class="access-panel-inner">
          <div class="access-panel-header">
            <div>
              <small>تسجيل الدخول</small>
              <h3>اختر نوع الحساب المناسب</h3>
            </div>
            <div class="secure-icon">🔐</div>
          </div>
          <div class="role-grid">
            <a class="role-card main-role" href="/web/login">
              <span class="role-icon">🏛️</span>
              <h4>مسؤولو الوقف</h4>
              <p>الإعدادات، الاعتمادات، المحافظ، ولوحات القرار.</p>
            </a>
            <a class="role-card" href="/web/login">
              <span class="role-icon">📊</span>
              <h4>مديرو المشاريع</h4>
              <p>إدارة المواقع، المستشارين، أوامر التغيير، ومواعيد التسليم.</p>
            </a>
            <a class="role-card" href="/contractor">
              <span class="role-icon">📱</span>
              <h4>المستشار المقيم</h4>
              <p>الحضور بالإحداثيات، التقارير، المراجعة، وفحص الاستلام.</p>
            </a>
            <a class="role-card" href="/contractor">
              <span class="role-icon">👷</span>
              <h4>المقاول المنفذ</h4>
              <p>تحديث التقدم، طلب المستخلصات، ورفع أوامر التغيير.</p>
            </a>
          </div>
          <div class="panel-note">
            كل دور يعمل من خلال صلاحيات محددة وتسجيل دخول آمن.
            تأكد من اختيار الدور الصحيح للوصول إلى لوحة التحكم المناسبة.
          </div>
          <a class="panel-login-main" href="/web/login">دخول النظام →</a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Quick highlights -->
  <section class="quick-section">
    <div class="container quick-grid">
      <article class="card quick-card">
        <div class="icon-box">⌖</div>
        <h3>تحقق جغرافي</h3>
        <p>تسجيل حضور وانصراف المستشار المقيم داخل إحداثيات موقع المسجد فقط.</p>
      </article>
      <article class="card quick-card">
        <div class="icon-box gold">▣</div>
        <h3>مستخلصات موثقة</h3>
        <p>طلبات صرف مرتبطة بالشواهد، والموافقات، وسجل تدقيق واضح.</p>
      </article>
