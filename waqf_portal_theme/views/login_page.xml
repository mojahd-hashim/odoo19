<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="tmpl_login" name="Waqf Login Page">
<t t-call="web.layout">
<t t-set="head">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
  <link rel="stylesheet" href="/waqf_portal_theme/static/src/css/theme.css"/>
</t>
<body class="waqf-login">
<div class="wl-login">

  <!-- ══ Left: Brand Panel ════════════════════════════════ -->
  <div class="ll-left">

    <!-- Mosque silhouette art (bottom) -->
    <div class="ll-mosque">
      <svg viewBox="0 0 800 140" xmlns="http://www.w3.org/2000/svg">
        <!-- main dome -->
        <ellipse cx="400" cy="72" rx="82" ry="82"/>
        <rect x="318" y="72" width="164" height="68"/>
        <!-- minarets -->
        <rect x="236" y="32" width="20" height="108"/>
        <ellipse cx="246" cy="32" rx="10" ry="19"/>
        <rect x="544" y="32" width="20" height="108"/>
        <ellipse cx="554" cy="32" rx="10" ry="19"/>
        <!-- side domes -->
        <ellipse cx="306" cy="98" rx="34" ry="34"/>
        <rect x="272" y="98" width="68" height="42"/>
        <ellipse cx="494" cy="98" rx="34" ry="34"/>
        <rect x="460" y="98" width="68" height="42"/>
        <!-- ground -->
        <rect x="0" y="138" width="800" height="2"/>
      </svg>
    </div>

    <div class="ll-content">

      <!-- Logo -->
      <div class="ll-logo">
        <t t-if="company and company.logo">
          <img t-att-src="'/web/image/res.company/%d/logo' % company.id"
               t-att-alt="company.name"/>
        </t>
        <t t-else="">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C10 4 8 5 8 8h8c0-3-2-4-4-6z"/>
            <path d="M4 22V12a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10"/>
            <path d="M2 22h20"/>
            <path d="M7 22v-6h10v6"/>
          </svg>
        </t>
      </div>

      <!-- Company name — bold prominent -->
      <div class="ll-company"
           t-esc="company.name if company else 'وقف خادم الحرمين الشريفين'"/>
      <div class="ll-project">
        نظام متابعة تأهيل المساجد<br/>برنامج الصيانة والتأهيل 1446هـ
      </div>

      <!-- Features list -->
      <div class="ll-feats">
        <div class="ll-feat">
          <div class="ll-feat-ico">
            <!-- chart icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 3v18h18"/>
              <path d="M7 16l4-4 4 4 4-4"/>
            </svg>
          </div>
          <div class="ll-feat-txt">لوحة إدارة تنفيذية بمؤشرات أداء حية</div>
        </div>
        <div class="ll-feat">
          <div class="ll-feat-ico">
            <!-- document check icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14,2 14,8 20,8"/>
              <polyline points="9,15 11,17 15,13"/>
            </svg>
          </div>
          <div class="ll-feat-txt">اعتماد المستخلصات وأوامر التغيير</div>
        </div>
        <div class="ll-feat">
          <div class="ll-feat-ico">
            <!-- location pin icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="ll-feat-txt">تتبع الحضور الميداني بتقنية GPS</div>
        </div>
        <div class="ll-feat">
          <div class="ll-feat-ico">
            <!-- AI / robot icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="10" rx="2"/>
              <circle cx="12" cy="5" r="2"/>
              <path d="M12 7v4"/>
              <line x1="8" y1="15" x2="8" y2="15"/>
              <line x1="12" y1="15" x2="12" y2="15"/>
              <line x1="16" y1="15" x2="16" y2="15"/>
            </svg>
          </div>
          <div class="ll-feat-txt">مساعد ذكاء اصطناعي لمتابعة المشاريع</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ Right: Form Panel ════════════════════════════════ -->
  <div class="ll-right">

    <!-- Small logo row -->
    <div class="fr-logo">
      <div class="fr-logo-ico">
        <t t-if="company and company.logo">
          <img t-att-src="'/web/image/res.company/%d/logo' % company.id"
               t-att-alt="company.name"/>
        </t>
        <t t-else="">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C10 4 8 5 8 8h8c0-3-2-4-4-6z"/>
            <path d="M4 22V12a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10"/>
            <path d="M2 22h20"/>
          </svg>
        </t>
      </div>
      <div class="fr-logo-name"
           t-esc="company.name if company else 'وقف خادم الحرمين الشريفين'"/>
    </div>

    <div class="fr-heading">مرحباً بك</div>
    <div class="fr-sub">سجّل دخولك للمتابعة</div>

    <!-- Error -->
    <t t-if="error">
      <div class="fr-error">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span>
          <t t-if="error == 'wrong_login'">بيانات الدخول غير صحيحة. تحقق من البريد وكلمة المرور.</t>
          <t t-elif="error == 'inactive'">هذا الحساب غير نشط. تواصل مع المسؤول.</t>
          <t t-else=""><t t-esc="error"/></t>
        </span>
      </div>
    </t>

    <!-- Login Form — Odoo 19 compatible -->
    <form action="/web/login" method="post">
      <input type="hidden" name="csrf_token"
             t-att-value="request.csrf_token() if request else ''"/>
      <t t-if="redirect">
        <input type="hidden" name="redirect" t-att-value="redirect"/>
      </t>

      <!-- Email -->
      <div class="fr-field">
        <label class="fr-label" for="login">
          <!-- Envelope icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M2 7l10 7 10-7"/>
          </svg>
          البريد الإلكتروني
        </label>
        <input class="fr-input"
               type="email"
               name="login"
               id="login"
               autocomplete="username"
               placeholder="your@email.com"
               t-att-value="login or ''"
               required="required"/>
      </div>

      <!-- Password -->
      <div class="fr-field">
        <label class="fr-label" for="password">
          <!-- Lock icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          كلمة المرور
        </label>
        <input class="fr-input"
               type="password"
               name="password"
               id="password"
               autocomplete="current-password"
               placeholder="••••••••"
               required="required"/>
      </div>

      <!-- Submit -->
      <button type="submit" class="fr-submit">
        <!-- Login arrow icon -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <polyline points="10 17 15 12 10 7"/>
          <line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
        دخول النظام
      </button>
    </form>

    <!-- Divider -->
    <div class="fr-divider">
      <div class="fr-div-line"/>
      <div class="fr-div-txt">أو</div>
      <div class="fr-div-line"/>
    </div>

    <!-- Contractor portal link -->
    <a class="fr-contractor" href="/contractor">
      <div class="fr-c-ico">
        <!-- Hard hat icon -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 18h20"/>
          <path d="M12 2v6"/>
          <path d="M4.93 7.93A8 8 0 0 1 20 13H4a8 8 0 0 1 .93-5.07z"/>
        </svg>
      </div>
      <div class="fr-c-body">
        <div class="fr-c-title">بوابة المشرفين الميدانيين</div>
        <div class="fr-c-sub">للمقاولين وفرق العمل في المواقع</div>
      </div>
      <div class="fr-c-arr">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </div>
    </a>

    <!-- Footer -->
    <div class="fr-footer">
      <a href="/">← العودة للصفحة الرئيسية</a><br/>
      <span style="margin-top:5px;display:block;font-size:10px">
        نظام محمي خاص بموظفي الوقف والجهات المعتمدة
      </span>
    </div>

  </div><!-- /ll-right -->
</div><!-- /wl-login -->

<script>
  // Auto-focus: if login is pre-filled, focus password
  document.addEventListener('DOMContentLoaded', function () {
    var l = document.getElementById('login');
    var p = document.getElementById('password');
    if (l &amp;&amp; l.value &amp;&amp; p) p.focus();
  });
</script>
</body>
</t>
</template>
</odoo>