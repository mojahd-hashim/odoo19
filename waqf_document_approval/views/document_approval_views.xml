<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════
         LIST VIEW — للاستشاري
    ══════════════════════════════════════════════════ -->
    <record id="view_doc_approval_list" model="ir.ui.view">
        <field name="name">doc.approval.list</field>
        <field name="model">waqf.document.approval</field>
        <field name="arch" type="xml">
            <list decoration-warning="state=='submitted'"
                  decoration-success="state in ('approved','approved_comments')"
                  decoration-danger="state=='rejected'"
                  decoration-muted="state=='draft'">
                <field name="name"/>
                <field name="title"/>
                <field name="mosque_id"/>
                <field name="doc_type_id"/>
                <field name="contractor_id"/>
                <field name="file_count" string="ملفات"/>
                <field name="total_size" string="MB" digits="[8,1]"/>
                <field name="revision" string="مراجعة"/>
                <field name="create_date"/>
                <field name="state" widget="badge"
                       decoration-warning="state=='submitted'"
                       decoration-success="state in ('approved','approved_comments')"
                       decoration-danger="state=='rejected'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════
         FORM VIEW — شاشة اعتماد الاستشاري
    ══════════════════════════════════════════════════ -->
    <record id="view_doc_approval_form" model="ir.ui.view">
        <field name="name">doc.approval.form</field>
        <field name="model">waqf.document.approval</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- أزرار الاستشاري -->
                    <button name="action_approve" type="object"
                            string="اعتماد" class="btn-success"
                            invisible="state != 'submitted'"
                            groups="waqf_document_approval.group_doc_consultant"/>
                    <button name="action_approve_comments" type="object"
                            string="اعتماد مع ملاحظات" class="btn-info"
                            invisible="state != 'submitted'"
                            groups="waqf_document_approval.group_doc_consultant"/>
                    <button name="action_reject" type="object"
                            string="رفض" class="btn-danger"
                            invisible="state != 'submitted'"
                            groups="waqf_document_approval.group_doc_consultant"/>
                    <button name="action_reset_draft" type="object"
                            string="إعادة لمسودة"
                            invisible="state == 'draft'"
                            groups="base.group_system"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h2><field name="title" placeholder="عنوان الطلب"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="mosque_id"/>
                            <field name="doc_type_id"/>
                            <field name="work_order_id"/>
                            <field name="revision"/>
                        </group>
                        <group>
                            <field name="contractor_id"/>
                            <field name="submitted_by"/>
                            <field name="reviewed_by"/>
                            <field name="review_date"/>
                            <field name="file_count"/>
                            <field name="total_size" digits="[8,2]"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="الملفات" name="files">
                            <field name="file_ids" readonly="1">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="file_size_human" string="الحجم"/>
                                    <field name="mimetype"/>
                                    <field name="note"/>
                                    <button name="action_download" type="object"
                                            string="تحميل" icon="fa-download"/>
                                </list>
                            </field>
                        </page>
                        <page string="الوصف والملاحظات" name="notes">
                            <group>
                                <field name="description" placeholder="وصف المقدّم..."/>
                                <field name="review_notes"
                                       placeholder="ملاحظات الاستشاري..."/>
                                <field name="reject_reason"
                                       placeholder="سبب الرفض..."
                                       invisible="state not in ('submitted','rejected')"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════
         SEARCH
    ══════════════════════════════════════════════════ -->
    <record id="view_doc_approval_search" model="ir.ui.view">
        <field name="name">doc.approval.search</field>
        <field name="model">waqf.document.approval</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <field name="mosque_id"/>
                <field name="contractor_id"/>
                <filter name="f_submitted" string="بانتظار الاعتماد"
                        domain="[('state','=','submitted')]"/>
                <filter name="f_approved" string="معتمد"
                        domain="[('state','in',('approved','approved_comments'))]"/>
                <filter name="f_rejected" string="مرفوض"
                        domain="[('state','=','rejected')]"/>
                <separator/>
                <group expand="0" string="تجميع">
                    <filter name="g_mosque" string="المسجد"
                            context="{'group_by':'mosque_id'}"/>
                    <filter name="g_type" string="نوع الوثيقة"
                            context="{'group_by':'doc_type_id'}"/>
                    <filter name="g_state" string="الحالة"
                            context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════
         ACTIONS
    ══════════════════════════════════════════════════ -->
    <record id="action_doc_approval" model="ir.actions.act_window">
        <field name="name">طلبات اعتماد الوثائق</field>
        <field name="res_model">waqf.document.approval</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_f_submitted': 1}</field>
    </record>

    <record id="action_doc_type" model="ir.actions.act_window">
        <field name="name">أنواع الوثائق</field>
        <field name="res_model">waqf.document.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
